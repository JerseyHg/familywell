{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["ES2017"],
    "typeRoots": ["./typings"],
    "paths": {
      "@/*": ["./miniprogram/*"]
    }
  },
  "include": ["./miniprogram/**/*.ts"],
  "exclude": ["node_modules"]
}
