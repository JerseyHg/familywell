/* pages/record-detail/record-detail.wxss */

page { background: var(--bg); }
.safe-top { height: calc(44px + env(safe-area-inset-top)); }
.safe-bottom { height: calc(120rpx + env(safe-area-inset-bottom)); }

/* ── Loading ── */
.loading-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding-top: 200rpx;
}
.loading-dots { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.dot-anim {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: var(--primary);
  animation: dotBounce 0.6s ease-in-out infinite alternate;
}
.dot-anim:nth-child(2) { animation-delay: 0.2s; }
.dot-anim:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotBounce { to { opacity: 0.3; transform: translateY(-10rpx); } }
.loading-text { color: var(--sub); font-size: 26rpx; }

/* ── Image Section ── */
.image-section {
  margin: 24rpx 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  background: var(--card);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}
.record-image { width: 100%; display: block; }
.image-hint {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 16rpx; text-align: center;
  background: rgba(0,0,0,0.4); color: #fff;
  font-size: 22rpx;
}

/* ── Info Card ── */
.info-card {
  margin: 24rpx 32rpx;
  background: var(--card);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.info-header {
  display: flex; align-items: center; gap: 20rpx;
  margin-bottom: 24rpx;
}
.info-icon { font-size: 48rpx; }
.info-title-area { flex: 1; }
.info-title {
  display: block; font-size: 34rpx; font-weight: 700; color: var(--text);
}
.info-category {
  display: block; font-size: 24rpx; color: var(--sub); margin-top: 4rpx;
}
.header-actions { display: flex; gap: 12rpx; }
.edit-btn {
  padding: 12rpx 28rpx; border-radius: 20rpx;
  background: var(--primary-light); color: var(--primary);
  font-size: 24rpx; font-weight: 600;
}
.delete-btn {
  padding: 12rpx 28rpx; border-radius: 20rpx;
  background: #FEF2F2; color: #E53935;
  font-size: 24rpx; font-weight: 600;
}

.info-row {
  display: flex; align-items: baseline; gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.info-row:last-child { border-bottom: none; }
.info-label {
  font-size: 24rpx; color: var(--sub); width: 100rpx; flex-shrink: 0;
}
.info-value { font-size: 28rpx; color: var(--text); flex: 1; }

/* ── Edit Mode ── */
.edit-row { margin-bottom: 24rpx; }
.edit-label { display: block; font-size: 24rpx; color: var(--sub); margin-bottom: 8rpx; }
.edit-input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: var(--bg); border-radius: 16rpx;
  font-size: 28rpx; color: var(--text);
  box-sizing: border-box;
}
.edit-picker {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: var(--bg); border-radius: 16rpx;
  font-size: 28rpx; color: var(--text);
}
.edit-textarea {
  width: 100%; min-height: 120rpx; padding: 16rpx 20rpx;
  background: var(--bg); border-radius: 16rpx;
  font-size: 28rpx; color: var(--text);
  box-sizing: border-box;
}
.edit-actions {
  display: flex; gap: 20rpx; margin-top: 24rpx;
}
.edit-cancel {
  flex: 1; text-align: center;
  padding: 20rpx; border-radius: 20rpx;
  background: var(--bg); color: var(--sub);
  font-size: 28rpx;
}
.edit-save {
  flex: 1; text-align: center;
  padding: 20rpx; border-radius: 20rpx;
  background: var(--primary); color: #fff;
  font-size: 28rpx; font-weight: 600;
}

/* ── Warnings ── */
.warnings-card {
  margin: 24rpx 32rpx; padding: 24rpx 28rpx;
  background: #FFF8E6; border-radius: 20rpx;
  border: 1rpx solid #FFE0A1;
}
.warn-title { display: block; font-size: 26rpx; font-weight: 600; color: #B7791F; margin-bottom: 12rpx; }
.warn-item { padding: 6rpx 0; }
.warn-text { font-size: 24rpx; color: #975A16; }

/* ── Section Cards ── */
.section-card {
  margin: 24rpx 32rpx;
  background: var(--card);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.section-title {
  display: block; font-size: 30rpx; font-weight: 700;
  color: var(--text); margin-bottom: 20rpx;
}

/* ── Indicators Grid ── */
.indicator-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx;
}
.indicator-item {
  padding: 20rpx; border-radius: 16rpx;
  background: var(--bg); position: relative;
}
.indicator-item.abnormal {
  background: #FEF2F2; border: 1rpx solid #FCA5A5;
}
.ind-name { display: block; font-size: 22rpx; color: var(--sub); }
.ind-value { display: block; font-size: 34rpx; font-weight: 700; color: var(--text); margin-top: 4rpx; }
.ind-unit { font-size: 22rpx; font-weight: 400; color: var(--sub); }
.ind-ref { display: block; font-size: 20rpx; color: var(--muted); margin-top: 4rpx; }
.ind-badge {
  position: absolute; top: 12rpx; right: 12rpx;
  padding: 4rpx 12rpx; border-radius: 8rpx;
  background: #EF4444; color: #fff;
  font-size: 18rpx; font-weight: 600;
}

/* ── Medications ── */
.confirm-hint {
  display: block; font-size: 24rpx; color: var(--sub); margin-bottom: 16rpx;
}
.med-confirm-list { margin-bottom: 24rpx; }
.med-confirm-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 20rpx 0; border-bottom: 1rpx solid var(--border);
}
.med-confirm-item:last-child { border-bottom: none; }
.med-checkbox {
  width: 48rpx; height: 48rpx; border-radius: 12rpx;
  border: 2rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 28rpx; color: #fff;
}
.med-checkbox.checked {
  background: var(--primary); border-color: var(--primary);
}
.med-confirm-info { flex: 1; }
.med-name { display: block; font-size: 28rpx; font-weight: 600; color: var(--text); }
.med-detail { display: block; font-size: 22rpx; color: var(--sub); margin-top: 4rpx; }

.confirm-btn {
  text-align: center; padding: 24rpx;
  border-radius: 24rpx;
  background: var(--primary); color: #fff;
  font-size: 30rpx; font-weight: 600;
}

.med-list { }
.med-item {
  padding: 16rpx 0; border-bottom: 1rpx solid var(--border);
}
.med-item:last-child { border-bottom: none; }

/* ── Raw Text ── */
.raw-text {
  font-size: 24rpx; color: var(--sub);
  line-height: 1.8; white-space: pre-wrap;
  max-height: 600rpx; overflow-y: auto;
}

/* ── Bottom Actions ── */
.bottom-actions {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--card);
  border-top: 1rpx solid var(--border);
}
.action-ask-ai {
  text-align: center; padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #2D8B6F, #3CC492);
  color: #fff; font-size: 30rpx; font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(45,139,111,0.3);
}
