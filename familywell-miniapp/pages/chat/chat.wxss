/* ══════════════════════════════
   FamilyWell — Chat Page Styles
   ★ Fix 1: safe-top 顶部安全区
   ★ Fix 4: 平滑滚动
   ══════════════════════════════ */

page { background: var(--bg); height: 100vh; overflow: hidden; }

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 100rpx);
  box-sizing: border-box;
  overflow: hidden;
  width: 100vw;
}

/* ★ 顶部安全区留白 — 统一所有页面 */
.safe-top {
  height: calc(44px + env(safe-area-inset-top));
  flex-shrink: 0;
  background: var(--card);
}

/* ── Header ── */
.chat-header {
  background: var(--card);
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}
.chat-header-inner { padding: 20rpx 40rpx 24rpx; }
.chat-title-row { display: flex; justify-content: space-between; align-items: center; }
.chat-title { font-size: 36rpx; font-weight: 700; color: var(--text); }
.chat-subtitle { display: block; font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }
.new-chat-btn {
  padding: 8rpx 24rpx; border-radius: 24rpx;
  background: var(--primary-light); color: var(--primary);
  font-size: 22rpx; font-weight: 600;
}

/* ── Message Area ── */
/* ★ Fix 4: 平滑滚动 */
.message-area {
  flex: 1;
  padding: 20rpx 0;
  overflow-y: auto;
  width: 100%;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
}
.scroll-bottom { height: 20rpx; }

/* ── Message Rows ── */
.msg-row {
  margin-bottom: 16rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  width: 100%;
}
.msg-row.user { display: flex; justify-content: flex-end; }

/* ── User Bubble ── */
.user-bubble {
  max-width: 75%;
  background: var(--primary);
  color: #fff;
  padding: 20rpx 32rpx;
  border-radius: 32rpx 8rpx 32rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

/* ── AI Bubble ── */
.ai-row { display: flex; gap: 16rpx; align-items: flex-start; }
.ai-avatar-sm {
  width: 56rpx; height: 56rpx; border-radius: 28rpx;
  background: linear-gradient(135deg, #2D8B6F, #4DB892);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.ai-bubble-group { flex: 1; min-width: 0; }
.ai-bubble {
  background: var(--card);
  padding: 20rpx 28rpx;
  border-radius: 8rpx 32rpx 32rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.ai-bubble-text { font-size: 28rpx; color: var(--text); line-height: 1.8; }

/* ── Typing ── */
.typing-bubble { padding: 20rpx 32rpx; }
.typing-dots { display: flex; gap: 10rpx; }
.dot-anim {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: var(--muted);
  animation: dotBounce 1.2s infinite;
}
.dot-anim:nth-child(2) { animation-delay: 0.2s; }
.dot-anim:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotBounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-8rpx); opacity: 1; }
}

/* ── Welcome ── */
.welcome {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 32rpx 40rpx;
}
.welcome-avatar { font-size: 80rpx; margin-bottom: 16rpx; }
.welcome-title { font-size: 36rpx; font-weight: 700; color: var(--text); }
.welcome-desc { font-size: 24rpx; color: var(--muted); margin-top: 8rpx; }
.welcome-prompts {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  margin-top: 40rpx; width: 100%;
}
.welcome-prompt {
  display: flex; align-items: center; gap: 10rpx;
  padding: 20rpx 28rpx; border-radius: 24rpx;
  background: var(--card);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.wp-icon { font-size: 28rpx; }
.wp-text { font-size: 26rpx; color: var(--text); }

/* ══════════════════════════════
   Chart Cards (all types)
   ══════════════════════════════ */
.chart-card {
  margin-top: 12rpx;
  background: var(--card);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.chart-header { display: flex; align-items: center; gap: 8rpx; margin-bottom: 16rpx; }
.chart-icon { font-size: 28rpx; }
.chart-title { font-size: 28rpx; font-weight: 600; color: var(--text); }
.chart-body { padding: 8rpx 0; }

/* ── Bar / Stack ── */
.bar-row { display: flex; align-items: flex-end; justify-content: space-around; gap: 8rpx; min-height: 120rpx; }
.bar-row.compact { min-height: 80rpx; }
.bar-col { display: flex; flex-direction: column; align-items: center; gap: 8rpx; flex: 1; }
.bar-stack { display: flex; flex-direction: column-reverse; gap: 2rpx; min-height: 4rpx; }
.bar-seg { width: 28rpx; border-radius: 4rpx; min-height: 4rpx; }
.bar-seg.single { width: 24rpx; border-radius: 4rpx; }
.bar-label { font-size: 18rpx; color: var(--muted); text-align: center; }
.dual-bars { display: flex; gap: 4rpx; align-items: flex-end; }

.chart-legend { display: flex; justify-content: center; gap: 24rpx; margin-top: 16rpx; }
.legend-item { display: flex; align-items: center; gap: 6rpx; font-size: 22rpx; color: var(--sub); }
.legend-dot { width: 14rpx; height: 14rpx; border-radius: 4rpx; }

/* ── Pie Chart ── */
.pie-wrapper {
  display: flex; align-items: center; justify-content: center;
  position: relative; margin: 16rpx 0 24rpx;
}
.pie-chart {
  width: 200rpx; height: 200rpx; border-radius: 50%;
}
.pie-center {
  position: absolute;
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: var(--card);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.pie-cal { font-size: 32rpx; font-weight: 700; color: var(--text); }
.pie-cal-unit { font-size: 18rpx; color: var(--muted); }
.pie-legend { display: flex; justify-content: center; gap: 32rpx; margin-bottom: 16rpx; }
.pie-legend-item { display: flex; align-items: center; gap: 8rpx; }
.pie-legend-dot { width: 16rpx; height: 16rpx; border-radius: 4rpx; }
.pie-legend-name { font-size: 22rpx; color: var(--sub); }
.pie-legend-val { font-size: 22rpx; font-weight: 600; color: var(--text); }
.pie-footer { text-align: center; }
.pf-item { display: inline-block; font-size: 22rpx; color: var(--sub); margin: 0 16rpx; }

/* ── Trend ── */
.trend-header { display: flex; align-items: baseline; gap: 8rpx; margin-bottom: 16rpx; }
.trend-latest { font-size: 44rpx; font-weight: 700; color: var(--text); }
.trend-unit { font-size: 22rpx; color: var(--sub); }
.trend-change { font-size: 24rpx; font-weight: 600; }
.trend-change.up { color: #E85D3A; }
.trend-change.down { color: #2D8B6F; }
.dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: var(--primary);
}

/* ── Adherence ── */
.adherence-header { display: flex; align-items: center; gap: 24rpx; margin-bottom: 20rpx; }
.adherence-ring {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  border: 8rpx solid var(--primary);
  display: flex; align-items: center; justify-content: center;
}
.ring-num { font-size: 28rpx; font-weight: 700; color: var(--primary); }
.adherence-stats { display: flex; flex-direction: column; gap: 4rpx; }
.ad-stat { font-size: 24rpx; color: var(--sub); }
.ad-stat.missed { color: var(--accent, #E85D3A); }

.med-progress { display: flex; align-items: center; gap: 12rpx; margin-top: 12rpx; }
.med-name { font-size: 24rpx; color: var(--text); width: 160rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.med-bar-bg { flex: 1; height: 16rpx; background: var(--bg); border-radius: 8rpx; overflow: hidden; }
.med-bar-fill { height: 100%; border-radius: 8rpx; transition: width 0.3s; }
.med-ratio { font-size: 20rpx; color: var(--sub); width: 60rpx; text-align: right; }

/* ── Alerts ── */
.alert-item { display: flex; align-items: flex-start; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid var(--border); }
.alert-item:last-child { border-bottom: none; }
.alert-icon { font-size: 28rpx; margin-top: 4rpx; }
.alert-info { flex: 1; }
.alert-title { display: block; font-size: 26rpx; font-weight: 600; color: var(--accent); }
.alert-desc { display: block; font-size: 22rpx; color: var(--sub); margin-top: 4rpx; }

/* ── Insurance ── */
.ins-item { padding: 12rpx 0; border-bottom: 1rpx solid var(--border); }
.ins-item:last-child { border-bottom: none; }
.ins-header-row { display: flex; justify-content: space-between; align-items: center; }
.ins-name { font-size: 26rpx; font-weight: 600; color: var(--text); }
.ins-urgent {
  padding: 4rpx 16rpx; border-radius: 12rpx;
  background: var(--accent-light); color: var(--accent);
  font-size: 20rpx; font-weight: 600;
}
.ins-detail { display: block; font-size: 22rpx; color: var(--sub); margin-top: 4rpx; }

/* ── Chart AI Tip ── */
.chart-ai-tip {
  display: flex; gap: 10rpx; align-items: flex-start;
  margin-top: 16rpx; padding: 16rpx 20rpx;
  background: #F5F8FF; border-radius: 16rpx;
}
.tip-icon { font-size: 22rpx; flex-shrink: 0; }
.tip-text { font-size: 22rpx; color: var(--sub); line-height: 1.5; }

/* ── Follow-up Prompts ── */
.followup-area { padding: 12rpx 32rpx; }
.followup-wrap { display: flex; flex-wrap: wrap; gap: 12rpx; }
.followup-chip {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 14rpx 28rpx; border-radius: 36rpx;
  background: var(--card);
  border: 1rpx solid var(--border);
  font-size: 22rpx; color: var(--sub);
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
}

/* ── Input Bar ── */
.input-bar {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 32rpx 16rpx;
  background: var(--card);
  border-top: 1rpx solid var(--border);
  flex-shrink: 0;
  width: 100%;
  box-sizing: border-box;
}
.input-wrap {
  flex: 1; min-width: 0;
  background: var(--bg);
  border-radius: 44rpx;
  padding: 20rpx 32rpx;
  border: 1rpx solid var(--border);
}
.input-field { font-size: 28rpx; color: var(--text); width: 100%; }
.send-btn {
  width: 80rpx; height: 80rpx; border-radius: 40rpx;
  background: var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}
.send-btn.active { background: var(--primary); }
.send-arrow { color: #fff; font-size: 32rpx; font-weight: 700; }
