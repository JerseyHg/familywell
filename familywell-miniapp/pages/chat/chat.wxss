/* FamilyWell — Chat Page Styles
   ★ Fix: padding-bottom 留出 TabBar 空间 */

page { background: var(--bg); height: 100vh; overflow: hidden; }

.chat-page {
  display: flex; flex-direction: column; height: 100vh;
  /* ★ 关键：给自定义 TabBar 留空间 */
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  box-sizing: border-box; overflow: hidden; width: 100vw;
}
.safe-top { height: calc(44px + env(safe-area-inset-top)); flex-shrink: 0; background: var(--card); }

.chat-header { background: var(--card); border-bottom: 1rpx solid var(--border); flex-shrink: 0; }
.chat-header-inner { padding: 20rpx 40rpx 24rpx; }
.chat-title-row { display: flex; justify-content: space-between; align-items: center; }
.chat-title { font-size: 36rpx; font-weight: 700; color: var(--text); }
.chat-subtitle { display: block; font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }
.new-chat-btn {
  padding: 8rpx 24rpx; border-radius: 24rpx;
  background: var(--primary-light); color: var(--primary); font-size: 22rpx; font-weight: 600;
}

.message-area {
  flex: 1; padding: 20rpx 0; overflow-y: auto; width: 100%;
  box-sizing: border-box; -webkit-overflow-scrolling: touch;
}
.scroll-bottom { height: 20rpx; }

.msg-row { margin-bottom: 16rpx; padding: 0 32rpx; box-sizing: border-box; width: 100%; }
.msg-row.user { display: flex; justify-content: flex-end; }

.user-bubble {
  max-width: 75%; background: var(--primary); color: #fff;
  padding: 20rpx 32rpx; border-radius: 32rpx 8rpx 32rpx 32rpx;
  font-size: 28rpx; line-height: 1.6; word-break: break-word;
}
.voice-msg-indicator { display: flex; align-items: center; gap: 8rpx; }
.voice-msg-icon { font-size: 28rpx; }

.ai-row { display: flex; gap: 16rpx; align-items: flex-start; }
.ai-avatar-sm {
  width: 56rpx; height: 56rpx; border-radius: 28rpx;
  background: linear-gradient(135deg, #2D8B6F, #4DB892);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; flex-shrink: 0;
}
.ai-bubble-group { max-width: calc(100% - 80rpx); display: flex; flex-direction: column; gap: 12rpx; }
.ai-bubble {
  background: var(--card); padding: 24rpx 28rpx;
  border-radius: 8rpx 28rpx 28rpx 28rpx; border: 1rpx solid var(--border);
}
.ai-bubble-text { font-size: 28rpx; color: var(--text); line-height: 1.7; word-break: break-word; white-space: pre-wrap; }

.typing-bubble { padding: 20rpx 28rpx; }
.typing-dots { display: flex; gap: 8rpx; align-items: center; }
.dot-anim { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--muted); animation: typing-bounce 1.2s ease-in-out infinite; }
.dot-anim:nth-child(2) { animation-delay: 0.2s; }
.dot-anim:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing-bounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-8rpx); opacity: 1; }
}

.welcome { display: flex; flex-direction: column; align-items: center; padding: 80rpx 48rpx 40rpx; }
.welcome-avatar {
  width: 120rpx; height: 120rpx; border-radius: 60rpx;
  background: linear-gradient(135deg, #2D8B6F, #4DB892);
  display: flex; align-items: center; justify-content: center;
  font-size: 60rpx; margin-bottom: 24rpx;
}
.welcome-title { font-size: 34rpx; font-weight: 700; color: var(--text); margin-bottom: 8rpx; }
.welcome-desc { font-size: 24rpx; color: var(--muted); margin-bottom: 40rpx; }
.welcome-prompts { display: flex; flex-wrap: wrap; gap: 16rpx; justify-content: center; width: 100%; }
.welcome-prompt {
  display: flex; align-items: center; gap: 10rpx;
  padding: 20rpx 28rpx; border-radius: 20rpx;
  background: var(--card); border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  width: calc(50% - 8rpx); box-sizing: border-box;
}
.wp-icon { font-size: 28rpx; }
.wp-text { font-size: 24rpx; color: var(--sub); }

.chart-card {
  background: var(--card); border: 1rpx solid var(--border);
  border-radius: 20rpx; padding: 24rpx; width: 100%; box-sizing: border-box;
}
.chart-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.chart-icon { font-size: 28rpx; }
.chart-title { font-size: 26rpx; font-weight: 600; color: var(--text); }
.chart-period { font-size: 20rpx; color: var(--muted); margin-left: auto; }

/* ── Pie / Donut Ring Chart ── */
.pie-visual { display: flex; align-items: center; gap: 32rpx; padding: 12rpx 0; }
.pie-ring {
  width: 180rpx; height: 180rpx; border-radius: 50%;
  position: relative; flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.pie-ring-hole {
  position: absolute; top: 30rpx; left: 30rpx;
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: var(--card);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.pie-total-val { font-size: 32rpx; font-weight: 700; color: var(--text); line-height: 1.2; }
.pie-total-unit { font-size: 18rpx; color: var(--muted); }
.pie-legend { flex: 1; display: flex; flex-direction: column; gap: 14rpx; }
.pie-legend-row { display: flex; align-items: center; gap: 10rpx; }
.pie-legend-dot { width: 16rpx; height: 16rpx; border-radius: 4rpx; flex-shrink: 0; }
.pie-legend-name { font-size: 24rpx; color: var(--sub); flex: 1; }
.pie-legend-g { font-size: 24rpx; font-weight: 500; color: var(--text); }
.pie-legend-pct { font-size: 22rpx; color: var(--muted); width: 56rpx; text-align: right; }

/* ── Med Adherence V2 ── */
.med-item { margin-bottom: 20rpx; padding-bottom: 20rpx; border-bottom: 1rpx solid var(--border); }
.med-item:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
.med-top-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.med-name-v2 { font-size: 26rpx; font-weight: 500; color: var(--text); }
.med-badge { padding: 4rpx 16rpx; border-radius: 16rpx; font-size: 20rpx; font-weight: 500; }
.med-badge.good { background: rgba(45,139,111,0.1); color: #2D8B6F; }
.med-badge.warn { background: rgba(245,166,35,0.1); color: #F5A623; }
.med-bar-row { display: flex; align-items: center; gap: 16rpx; }
.med-bar-bg-v2 { flex: 1; height: 16rpx; background: var(--bg); border-radius: 8rpx; overflow: hidden; }
.med-bar-fill-v2 { height: 100%; border-radius: 8rpx; transition: width 0.8s ease; }
.med-pct-v2 { font-size: 28rpx; font-weight: 700; color: var(--text); min-width: 70rpx; text-align: right; }
.med-detail-v2 { font-size: 22rpx; color: var(--muted); margin-top: 8rpx; display: block; }

/* ── Indicator Cards V2 ── */
.ind-grid-v2 { display: flex; flex-wrap: wrap; gap: 16rpx; }
.ind-card-v2 {
  flex: 1; min-width: calc(50% - 8rpx); background: var(--bg); border-radius: 16rpx;
  padding: 20rpx; display: flex; flex-direction: column; align-items: center;
  gap: 4rpx; position: relative; border: 1rpx solid transparent; box-sizing: border-box;
}
.ind-card-v2.danger { background: rgba(229,91,91,0.06); border-color: rgba(229,91,91,0.15); }
.ind-card-v2.warning { background: rgba(245,166,35,0.06); border-color: rgba(245,166,35,0.15); }
.ind-card-v2.normal { background: rgba(45,139,111,0.06); border-color: rgba(45,139,111,0.15); }
.ind-dot-v2 {
  position: absolute; top: 14rpx; right: 14rpx;
  width: 12rpx; height: 12rpx; border-radius: 50%;
}
.ind-dot-v2.danger { background: #E55B5B; }
.ind-dot-v2.warning { background: #F5A623; }
.ind-dot-v2.normal { background: #2D8B6F; }
.ind-val-v2 { font-size: 36rpx; font-weight: 700; line-height: 1.2; }
.ind-unit-v2 { font-size: 20rpx; color: var(--muted); }
.ind-label-v2 { font-size: 22rpx; color: var(--sub); margin-top: 4rpx; }

/* ── Horizontal Bar Chart (line type) ── */
.hbar-chart { display: flex; flex-direction: column; gap: 16rpx; }
.hbar-row { display: flex; align-items: center; gap: 16rpx; }
.hbar-label { font-size: 24rpx; color: var(--sub); width: 100rpx; flex-shrink: 0; }
.hbar-track { flex: 1; height: 20rpx; background: var(--bg); border-radius: 10rpx; overflow: hidden; }
.hbar-fill { height: 100%; border-radius: 10rpx; transition: width 0.8s ease; }
.hbar-value { font-size: 24rpx; font-weight: 600; color: var(--text); min-width: 80rpx; text-align: right; }

/* ── Stacked Bar Chart ── */
.stack-chart {
  display: flex; align-items: flex-end; gap: 20rpx;
  justify-content: space-around; padding: 16rpx 0; min-height: 160rpx;
}
.stack-col { display: flex; flex-direction: column; align-items: center; gap: 8rpx; flex: 1; }
.stack-bars {
  display: flex; flex-direction: column-reverse;
  width: 44rpx; border-radius: 8rpx 8rpx 0 0; overflow: hidden;
}
.stack-seg { width: 100%; min-height: 4rpx; }
.stack-label { font-size: 20rpx; color: var(--muted); text-align: center; }
.stack-legend { display: flex; flex-wrap: wrap; gap: 20rpx; margin-top: 16rpx; justify-content: center; }
.stack-legend-item { display: flex; align-items: center; gap: 8rpx; }
.stack-legend-dot { width: 12rpx; height: 12rpx; border-radius: 3rpx; }
.stack-legend-text { font-size: 20rpx; color: var(--sub); }

/* ── Alert Cards ── */
.alert-card {
  display: flex; gap: 16rpx; padding: 16rpx;
  margin-bottom: 12rpx; background: var(--bg); border-radius: 12rpx;
}
.alert-card:last-child { margin-bottom: 0; }
.alert-icon-wrap {
  width: 48rpx; height: 48rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.alert-icon-wrap.med { background: rgba(155,89,182,0.1); }
.alert-icon-wrap.ins { background: rgba(45,139,111,0.1); }
.alert-icon-wrap.check { background: rgba(91,155,213,0.1); }
.alert-icon-wrap.other { background: rgba(245,166,35,0.1); }
.alert-icon-v2 { font-size: 24rpx; }
.alert-content { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.alert-title-v2 { font-size: 26rpx; font-weight: 500; color: var(--text); }
.alert-desc-v2 { font-size: 22rpx; color: var(--sub); line-height: 1.4; }

/* ── Insurance Cards ── */
.ins-card { padding: 16rpx; margin-bottom: 12rpx; background: var(--bg); border-radius: 12rpx; }
.ins-card:last-child { margin-bottom: 0; }
.ins-top-row { display: flex; align-items: center; justify-content: space-between; }
.ins-provider { font-size: 26rpx; font-weight: 600; color: var(--text); }
.ins-urgent-badge {
  padding: 4rpx 16rpx; border-radius: 16rpx;
  background: #FEF2F2; color: #E55B5B; font-size: 20rpx; font-weight: 600;
}
.ins-bottom-row { display: flex; align-items: center; justify-content: space-between; margin-top: 8rpx; }
.ins-date { font-size: 22rpx; color: var(--sub); }
.ins-days { font-size: 22rpx; color: var(--sub); }
.ins-days.urgent { color: #E55B5B; font-weight: 500; }

/* ── Chart AI Tip ── */
.chart-ai-tip { display: flex; gap: 10rpx; align-items: flex-start; margin-top: 16rpx; padding: 16rpx 20rpx; background: #F5F8FF; border-radius: 16rpx; }
.tip-icon { font-size: 22rpx; flex-shrink: 0; }
.tip-text { font-size: 22rpx; color: var(--sub); line-height: 1.5; }

.followup-area { padding: 12rpx 32rpx; }
.followup-wrap { display: flex; flex-wrap: wrap; gap: 12rpx; }
.followup-chip {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 14rpx 28rpx; border-radius: 36rpx;
  background: var(--card); border: 1rpx solid var(--border);
  font-size: 22rpx; color: var(--sub); box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
}

/* ★ Input Bar */
.input-bar {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 32rpx;
  background: var(--card); border-top: 1rpx solid var(--border);
  flex-shrink: 0; width: 100%; box-sizing: border-box;
}
.mode-toggle {
  width: 72rpx; height: 72rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 36rpx; background: var(--bg); border: 1rpx solid var(--border);
  font-size: 32rpx; flex-shrink: 0;
}
.input-wrap { flex: 1; min-width: 0; background: var(--bg); border-radius: 44rpx; padding: 20rpx 32rpx; border: 1rpx solid var(--border); }
.input-field { font-size: 28rpx; color: var(--text); width: 100%; }
.send-btn {
  width: 80rpx; height: 80rpx; border-radius: 40rpx; background: var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: background 0.2s;
}
.send-btn.active { background: var(--primary); }
.send-arrow { color: #fff; font-size: 32rpx; font-weight: 700; }

.voice-input-btn {
  flex: 1; height: 80rpx;
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  background: var(--bg); border: 2rpx solid var(--border);
  border-radius: 44rpx; transition: all 0.15s;
}
.voice-input-btn:active { background: #E8E4DD; }
.voice-input-btn.recording { background: #FEF2F2; border-color: #FECACA; }
.voice-input-icon { font-size: 36rpx; }
.voice-input-label { font-size: 28rpx; color: var(--text); font-weight: 500; }
.voice-input-label.recording { color: #DC2626; }

.voice-recording-wave { display: flex; align-items: center; gap: 4rpx; height: 40rpx; }
.v-wave-bar { width: 5rpx; height: 100%; border-radius: 3rpx; background: #DC2626; animation: v-wave-anim 0.8s ease-in-out infinite alternate; }
@keyframes v-wave-anim { 0% { transform: scaleY(0.3); } 100% { transform: scaleY(1); } }

.ai-disclaimer-badge { font-size: 20rpx; color: var(--muted); background: rgba(45,139,111,0.08); padding: 6rpx 16rpx; border-radius: 8rpx; margin-top: 8rpx; display: inline-block; }
.ai-disclaimer { padding: 8rpx 0 0; }
.disclaimer-text { font-size: 20rpx; color: var(--muted); line-height: 1.4; }
