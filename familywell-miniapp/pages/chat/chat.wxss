/* ══════════════════════════════
   FamilyWell — Chat Page Styles
   ══════════════════════════════ */

page { background: var(--bg); height: 100vh; overflow: hidden; }

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  /* ✅ 为底部自定义 TabBar 留出空间 */
  padding-bottom: calc(env(safe-area-inset-bottom) + 100rpx);
  box-sizing: border-box;
  /* ✅ 防止子元素溢出 */
  overflow: hidden;
  width: 100vw;
}

/* ── Header ── */
.chat-header {
  background: var(--card);
  border-bottom: 1rpx solid var(--border);
  padding-top: env(safe-area-inset-top);
  flex-shrink: 0;
}
.chat-header-inner { padding: 20rpx 40rpx 24rpx; }
.chat-title-row { display: flex; justify-content: space-between; align-items: center; }
.chat-title { font-size: 36rpx; font-weight: 700; color: var(--text); }
.chat-subtitle { display: block; font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }
.new-chat-btn {
  padding: 8rpx 24rpx; border-radius: 24rpx;
  background: var(--primary-light); color: var(--primary);
  font-size: 22rpx; font-weight: 600;
}

/* ── Message Area ── */
/* ✅ 修复：scroll-view 不加左右 padding（会导致内容溢出），
   改为在子元素 .msg-row 上加 padding */
.message-area {
  flex: 1;
  padding: 20rpx 0;
  overflow-y: auto;
  width: 100%;
  box-sizing: border-box;
}
.scroll-bottom { height: 20rpx; }

/* ── Message Rows ── */
/* ✅ 修复：padding 加在每行上，而不是 scroll-view 上，避免溢出 */
.msg-row {
  margin-bottom: 16rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  width: 100%;
}
.msg-row.user { display: flex; justify-content: flex-end; }

/* ── User Bubble ── */
.user-bubble {
  max-width: 75%;
  background: var(--primary);
  color: #fff;
  padding: 20rpx 32rpx;
  border-radius: 32rpx 8rpx 32rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

/* ── AI Bubble ── */
.ai-row { display: flex; gap: 16rpx; align-items: flex-start; }
.ai-avatar-sm {
  width: 56rpx; height: 56rpx; border-radius: 28rpx;
  background: linear-gradient(135deg, #2D8B6F, #4DB892);
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; flex-shrink: 0;
}
.ai-bubble-group {
  /* ✅ 修复：限制最大宽度，防止溢出 */
  max-width: calc(100% - 72rpx);
  min-width: 0;
  display: flex; flex-direction: column; gap: 12rpx;
}
.ai-bubble {
  background: var(--card);
  padding: 24rpx 32rpx;
  border-radius: 8rpx 32rpx 32rpx 32rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}
.ai-bubble-text {
  font-size: 27rpx; line-height: 1.7; color: var(--text);
  white-space: pre-line;
  word-break: break-word;
}

/* ── Welcome ── */
.welcome { text-align: center; padding: 60rpx 40rpx; }
.welcome-avatar {
  width: 112rpx; height: 112rpx; border-radius: 56rpx;
  background: linear-gradient(135deg, #2D8B6F, #4DB892);
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; margin: 0 auto 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(45,139,111,0.25);
}
.welcome-title { display: block; font-size: 32rpx; font-weight: 700; color: var(--text); }
.welcome-desc { display: block; font-size: 24rpx; color: var(--sub); margin-top: 8rpx; line-height: 1.6; }

/* ── Welcome Prompts（2x4 网格） ── */
.welcome-prompts {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  margin-top: 40rpx;
}
.welcome-prompt {
  display: flex; align-items: center; gap: 16rpx;
  width: calc(50% - 8rpx);
  padding: 24rpx 24rpx;
  border-radius: 32rpx;
  background: var(--card); border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
  box-sizing: border-box;
}
.wp-icon { font-size: 32rpx; flex-shrink: 0; }
.wp-text { font-size: 24rpx; font-weight: 500; color: var(--text); line-height: 1.4; }

/* ── Typing ── */
.typing-bubble { padding: 24rpx 36rpx; }
.typing-dots { display: flex; gap: 8rpx; }
.dot-anim {
  width: 12rpx; height: 12rpx; border-radius: 6rpx;
  background: var(--muted);
  animation: dotPulse 1.2s ease-in-out infinite;
}
.dot-anim:nth-child(2) { animation-delay: 0.2s; }
.dot-anim:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.3); }
}

/* ══════════════════════════════
   CHART CARDS
   ══════════════════════════════ */

.chart-card {
  background: var(--card);
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}
.chart-header {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 20rpx;
}
.chart-icon { font-size: 28rpx; }
.chart-title { font-size: 26rpx; font-weight: 700; color: var(--text); }

/* ── Bar Chart Shared ── */
.bar-row {
  display: flex; align-items: flex-end; justify-content: space-around;
  height: 180rpx; margin-bottom: 12rpx;
}
.bar-row.compact { height: 120rpx; }
.bar-col { display: flex; flex-direction: column; align-items: center; gap: 6rpx; flex: 1; }
.bar-stack { display: flex; flex-direction: column-reverse; align-items: center; }
.dual-bars { display: flex; align-items: flex-end; gap: 4rpx; }
.bar-seg { width: 28rpx; border-radius: 8rpx 8rpx 0 0; min-height: 4rpx; }
.bar-seg.single { width: 32rpx; border-radius: 8rpx 8rpx 0 0; }
.bar-label { font-size: 18rpx; color: var(--muted); }

/* ── Chart Legend ── */
.chart-legend { display: flex; justify-content: center; gap: 24rpx; margin-top: 12rpx; }
.legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 20rpx; color: var(--sub); }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 4rpx; }

/* ── Chart Stats ── */
.chart-stat { display: flex; align-items: baseline; gap: 8rpx; margin-top: 16rpx; }
.stat-big { font-size: 40rpx; font-weight: 700; color: var(--text); }
.stat-unit { font-size: 22rpx; color: var(--sub); }
.stat-change { font-size: 22rpx; font-weight: 600; margin-left: 12rpx; }
.stat-change.up { color: #E85D3A; }
.stat-change.down { color: #2D8B6F; }

/* ── Adherence Chart ── */
.adherence-summary { display: flex; align-items: center; gap: 24rpx; margin-bottom: 16rpx; }
.adherence-ring {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 700;
}
.adherence-detail { font-size: 24rpx; color: var(--sub); line-height: 1.8; }
.med-item { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.med-name { font-size: 24rpx; color: var(--text); width: 160rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.med-bar-bg { flex: 1; height: 16rpx; background: var(--bg); border-radius: 8rpx; overflow: hidden; }
.med-bar-fill { height: 100%; border-radius: 8rpx; transition: width 0.3s; }
.med-ratio { font-size: 20rpx; color: var(--sub); width: 60rpx; text-align: right; }

/* ── Alerts ── */
.alert-item { display: flex; align-items: flex-start; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid var(--border); }
.alert-item:last-child { border-bottom: none; }
.alert-icon { font-size: 28rpx; margin-top: 4rpx; }
.alert-info { flex: 1; }
.alert-title { display: block; font-size: 26rpx; font-weight: 600; color: var(--accent); }
.alert-desc { display: block; font-size: 22rpx; color: var(--sub); margin-top: 4rpx; }

/* ── Insurance ── */
.ins-item { padding: 12rpx 0; border-bottom: 1rpx solid var(--border); }
.ins-item:last-child { border-bottom: none; }
.ins-header-row { display: flex; justify-content: space-between; align-items: center; }
.ins-name { font-size: 26rpx; font-weight: 600; color: var(--text); }
.ins-urgent {
  padding: 4rpx 16rpx; border-radius: 12rpx;
  background: var(--accent-light); color: var(--accent);
  font-size: 20rpx; font-weight: 600;
}
.ins-detail { display: block; font-size: 22rpx; color: var(--sub); margin-top: 4rpx; }

/* ── Chart AI Tip ── */
.chart-ai-tip {
  display: flex; gap: 10rpx; align-items: flex-start;
  margin-top: 16rpx; padding: 16rpx 20rpx;
  background: #F5F8FF; border-radius: 16rpx;
}
.tip-icon { font-size: 22rpx; flex-shrink: 0; }
.tip-text { font-size: 22rpx; color: var(--sub); line-height: 1.5; }

/* ── Follow-up Prompts ── */
.followup-area { padding: 12rpx 32rpx; }
.followup-scroll { white-space: nowrap; }
.followup-chip {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 14rpx 28rpx; border-radius: 36rpx;
  background: var(--card); border: 1rpx solid var(--border);
  font-size: 22rpx; color: var(--sub);
  margin-right: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
}

/* ── Input Bar ── */
.input-bar {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 32rpx 16rpx;
  background: var(--card);
  border-top: 1rpx solid var(--border);
  flex-shrink: 0;
  width: 100%;
  box-sizing: border-box;
}
.input-wrap {
  flex: 1;
  min-width: 0;
  background: var(--bg);
  border-radius: 44rpx;
  padding: 20rpx 32rpx;
  border: 1rpx solid var(--border);
}
.input-field { font-size: 28rpx; color: var(--text); width: 100%; }
.send-btn {
  width: 80rpx; height: 80rpx; border-radius: 40rpx;
  background: var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}
.send-btn.active { background: var(--primary); }
.send-arrow { color: #fff; font-size: 32rpx; font-weight: 700; }
