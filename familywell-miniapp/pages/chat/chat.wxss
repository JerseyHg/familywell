/* ══════════════════════════════
   FamilyWell — Chat Page Styles
   ═══════════════════════════════
   ★ 修复：input-bar 位置不再和 TabBar 重叠（Problem 4）
   ★ 修复：followup 提示词改为 wrap 多排（Problem 5）
*/

page { background: var(--bg); height: 100vh; overflow: hidden; }

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  /* ★ 修复 Problem 4：为底部自定义 TabBar 留出精确空间 */
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  box-sizing: border-box;
  overflow: hidden;
  width: 100vw;
}

/* ── Header ── */
.chat-header {
  background: var(--card);
  border-bottom: 1rpx solid var(--border);
  padding-top: env(safe-area-inset-top);
  flex-shrink: 0;
}
.chat-header-inner { padding: 20rpx 40rpx 24rpx; }
.chat-title-row { display: flex; justify-content: space-between; align-items: center; }
.chat-title { font-size: 36rpx; font-weight: 700; color: var(--text); }
.chat-subtitle { display: block; font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }
.new-chat-btn {
  padding: 8rpx 24rpx; border-radius: 24rpx;
  background: var(--primary-light); color: var(--primary);
  font-size: 22rpx; font-weight: 600;
}

/* ── Message Area ── */
.message-area {
  flex: 1;
  padding: 20rpx 0;
  overflow-y: auto;
  width: 100%;
  box-sizing: border-box;
}
.scroll-bottom { height: 20rpx; }

/* ── Message Rows ── */
.msg-row {
  margin-bottom: 16rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  width: 100%;
}
.msg-row.user { display: flex; justify-content: flex-end; }

/* ── User Bubble ── */
.user-bubble {
  max-width: 75%;
  background: var(--primary);
  color: #fff;
  padding: 20rpx 32rpx;
  border-radius: 32rpx 8rpx 32rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

/* ── AI Bubble ── */
.ai-row { display: flex; gap: 16rpx; align-items: flex-start; }
.ai-avatar-sm {
  width: 56rpx; height: 56rpx; border-radius: 28rpx;
  background: linear-gradient(135deg, #2D8B6F, #4DB892);
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; flex-shrink: 0;
}
.ai-bubble-group {
  max-width: calc(100% - 72rpx);
  min-width: 0;
  display: flex; flex-direction: column; gap: 12rpx;
}
.ai-bubble {
  background: var(--card);
  padding: 24rpx 32rpx;
  border-radius: 8rpx 32rpx 32rpx 32rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}
.ai-bubble-text {
  font-size: 27rpx; line-height: 1.7; color: var(--text);
  white-space: pre-line;
  word-break: break-word;
}

/* ── Welcome ── */
.welcome { text-align: center; padding: 60rpx 40rpx; }
.welcome-avatar {
  width: 112rpx; height: 112rpx; border-radius: 56rpx;
  background: linear-gradient(135deg, #2D8B6F, #4DB892);
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; margin: 0 auto 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(45,139,111,0.25);
}
.welcome-title { display: block; font-size: 32rpx; font-weight: 700; color: var(--text); }
.welcome-desc { display: block; font-size: 24rpx; color: var(--sub); margin-top: 8rpx; line-height: 1.6; }

/* ── Welcome Prompts（2x4 网格） ── */
.welcome-prompts {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  margin-top: 40rpx;
}
.welcome-prompt {
  display: flex; align-items: center; gap: 16rpx;
  width: calc(50% - 8rpx);
  padding: 24rpx 24rpx;
  border-radius: 32rpx;
  background: var(--card); border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
  box-sizing: border-box;
}
.wp-icon { font-size: 32rpx; flex-shrink: 0; }
.wp-text { font-size: 24rpx; font-weight: 500; color: var(--text); line-height: 1.4; }

/* ── Typing ── */
.typing-bubble { padding: 24rpx 36rpx; }
.typing-dots { display: flex; gap: 8rpx; }
.dot-anim {
  width: 12rpx; height: 12rpx; border-radius: 6rpx;
  background: var(--muted);
  animation: dotPulse 1.2s ease-in-out infinite;
}
.dot-anim:nth-child(2) { animation-delay: 0.2s; }
.dot-anim:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.3); }
}

/* ═══════════════════════════════════════════
   ★ Follow-up Prompts — wrap 多排布局（Problem 5）
   ═══════════════════════════════════════════ */
.followup-area {
  padding: 12rpx 32rpx 8rpx;
}
/* 改为 flex-wrap，不再用 scroll-view 横向滚动 */
.followup-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.followup-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  border-radius: 36rpx;
  background: var(--card);
  border: 1rpx solid var(--border);
  font-size: 22rpx;
  color: var(--sub);
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
  white-space: nowrap;
}

/* ═══════════════════════════════════════════
   ★ Input Bar（Problem 4 修复位置）
   ═══════════════════════════════════════════ */
.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  /* ★ 加底部安全距离，避免和 TabBar 重叠 */
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--card);
  border-top: 1rpx solid var(--border);
  flex-shrink: 0;
  width: 100%;
  box-sizing: border-box;
}
.input-wrap {
  flex: 1;
  min-width: 0;
  background: var(--bg);
  border-radius: 44rpx;
  padding: 20rpx 32rpx;
  border: 1rpx solid var(--border);
}
.input-field { font-size: 28rpx; color: var(--text); width: 100%; }
.send-btn {
  width: 80rpx; height: 80rpx; border-radius: 40rpx;
  background: var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}
.send-btn.active { background: var(--primary); }
.send-arrow { color: #fff; font-size: 32rpx; font-weight: 700; }

/* ═══════════════════════════════════════════
   Charts
   ═══════════════════════════════════════════ */
.chart-card {
  background: var(--card);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.chart-header {
  display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx;
}
.chart-icon { font-size: 28rpx; }
.chart-title { font-size: 26rpx; font-weight: 700; color: var(--text); }
.chart-body { padding: 0; }

/* ── Pie Chart ── */
.pie-wrapper {
  display: flex; align-items: center; justify-content: center;
  position: relative; margin: 16rpx 0 24rpx;
}
.pie-chart {
  width: 200rpx; height: 200rpx; border-radius: 50%;
}
.pie-center {
  position: absolute;
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: var(--card);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.pie-cal { font-size: 32rpx; font-weight: 700; color: var(--text); }
.pie-cal-unit { font-size: 18rpx; color: var(--muted); }
.pie-legend { display: flex; justify-content: center; gap: 32rpx; margin-bottom: 16rpx; }
.pie-legend-item { display: flex; align-items: center; gap: 8rpx; }
.pie-legend-dot { width: 16rpx; height: 16rpx; border-radius: 4rpx; }
.pie-legend-name { font-size: 22rpx; color: var(--sub); }
.pie-legend-val { font-size: 22rpx; font-weight: 600; color: var(--text); }
.pie-footer { text-align: center; }
.pf-item { display: inline-block; font-size: 22rpx; color: var(--sub); margin: 0 16rpx; }

/* ── Blood Pressure ── */
.bp-latest { text-align: center; margin-bottom: 16rpx; }
.bp-val { font-size: 48rpx; font-weight: 800; color: var(--text); }
.bp-unit { font-size: 22rpx; color: var(--muted); margin-left: 8rpx; }
.line-bars { display: flex; align-items: flex-end; justify-content: space-around; height: 200rpx; padding: 0 16rpx; }
.bar-group { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.bar-pair { display: flex; gap: 4rpx; align-items: flex-end; }
.bar { width: 12rpx; border-radius: 6rpx; min-height: 4rpx; }
.bar-single { width: 20rpx; border-radius: 10rpx; min-height: 4rpx; }
.bar-label { font-size: 18rpx; color: var(--muted); }

/* ── Adherence ── */
.adh-ring-row { display: flex; align-items: center; gap: 24rpx; margin-bottom: 20rpx; }
.adh-ring {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.adh-ring-center {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: var(--card);
  display: flex; align-items: center; justify-content: center;
}
.adh-pct { font-size: 24rpx; font-weight: 700; color: var(--primary); }
.adh-stats { display: flex; flex-direction: column; gap: 8rpx; }
.adh-stat { font-size: 24rpx; color: var(--sub); line-height: 1.8; }
.med-list { margin-top: 12rpx; }
.med-item { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.med-name { font-size: 24rpx; color: var(--text); width: 160rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.med-bar-bg { flex: 1; height: 16rpx; background: var(--bg); border-radius: 8rpx; overflow: hidden; }
.med-bar-fill { height: 100%; border-radius: 8rpx; transition: width 0.3s; }
.med-ratio { font-size: 20rpx; color: var(--sub); width: 60rpx; text-align: right; }

/* ── Alerts ── */
.alert-item { display: flex; align-items: flex-start; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid var(--border); }
.alert-item:last-child { border-bottom: none; }
.alert-icon { font-size: 28rpx; margin-top: 4rpx; }
.alert-info { flex: 1; }
.alert-title { display: block; font-size: 26rpx; font-weight: 600; color: var(--accent); }
.alert-desc { display: block; font-size: 22rpx; color: var(--sub); margin-top: 4rpx; }

/* ── Insurance ── */
.ins-item { padding: 12rpx 0; border-bottom: 1rpx solid var(--border); }
.ins-item:last-child { border-bottom: none; }
.ins-header-row { display: flex; justify-content: space-between; align-items: center; }
.ins-name { font-size: 26rpx; font-weight: 600; color: var(--text); }
.ins-urgent {
  padding: 4rpx 16rpx; border-radius: 12rpx;
  background: var(--accent-light); color: var(--accent);
  font-size: 20rpx; font-weight: 600;
}
.ins-detail { display: block; font-size: 22rpx; color: var(--sub); margin-top: 4rpx; }

/* ── Chart AI Tip ── */
.chart-ai-tip {
  display: flex; gap: 10rpx; align-items: flex-start;
  margin-top: 16rpx; padding: 16rpx 20rpx;
  background: #F5F8FF; border-radius: 16rpx;
}
.tip-icon { font-size: 22rpx; flex-shrink: 0; }
.tip-text { font-size: 22rpx; color: var(--sub); line-height: 1.5; }
