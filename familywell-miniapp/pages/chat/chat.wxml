<view class="chat-page">

  <!-- ── Header ── -->
  <view class="chat-header">
    <view class="chat-header-inner">
      <view class="chat-title-row">
        <text class="chat-title">🤖 AI 健康助手</text>
        <view class="new-chat-btn" bindtap="onNewChat">新对话</view>
      </view>
      <text class="chat-subtitle">基于你的真实健康档案回答</text>
    </view>
  </view>

  <!-- ── Message List ── -->
  <scroll-view
    class="message-area"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    enhanced
    show-scrollbar="{{false}}"
  >

    <!-- Welcome (no messages) -->
    <view class="welcome" wx:if="{{messages.length === 0 && !typing}}">
      <view class="welcome-avatar">🤖</view>
      <text class="welcome-title">你好，我是健康助手</text>
      <text class="welcome-desc">我能看到全部健康档案，随时可以问我</text>

      <!-- Initial prompts -->
      <view class="welcome-prompts">
        <view
          class="welcome-prompt"
          wx:for="{{homePrompts}}"
          wx:key="text"
          data-text="{{item.text}}"
          bindtap="onPromptTap"
        >
          <text class="wp-icon">{{item.icon}}</text>
          <text class="wp-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- Messages -->
    <block wx:for="{{messages}}" wx:key="id">
      <view id="msg-{{index}}" class="msg-row {{item.role}}">

        <!-- User bubble -->
        <view class="user-bubble" wx:if="{{item.role === 'user'}}">
          <text>{{item.text}}</text>
        </view>

        <!-- Assistant bubble -->
        <view class="ai-row" wx:if="{{item.role === 'assistant'}}">
          <view class="ai-avatar-sm">🤖</view>
          <view class="ai-bubble-group">
            <!-- Charts -->
            <block wx:for="{{item.charts}}" wx:for-item="chart" wx:key="type">
              <view class="chart-card">
                <view class="chart-header">
                  <text class="chart-icon">{{chart.icon || '📊'}}</text>
                  <text class="chart-title">{{chart.title}}</text>
                </view>

                <!-- ── pie: 营养摄入 ── -->
                <view class="chart-body" wx:if="{{chart.type === 'pie'}}">
                  <view class="pie-wrapper">
                    <view class="pie-chart" style="background: conic-gradient(
                      {{chart.data[0].color}} 0% {{chart.data[0].value / (chart.data[0].value + chart.data[1].value + chart.data[2].value) * 100}}%,
                      {{chart.data[1].color}} {{chart.data[0].value / (chart.data[0].value + chart.data[1].value + chart.data[2].value) * 100}}% {{(chart.data[0].value + chart.data[1].value) / (chart.data[0].value + chart.data[1].value + chart.data[2].value) * 100}}%,
                      {{chart.data[2].color}} {{(chart.data[0].value + chart.data[1].value) / (chart.data[0].value + chart.data[1].value + chart.data[2].value) * 100}}% 100%);" />
                    <view class="pie-center">
                      <text class="pie-cal">{{chart.summary.total_calories}}</text>
                      <text class="pie-cal-unit">千卡</text>
                    </view>
                  </view>
                  <view class="pie-legend">
                    <view class="pie-legend-item" wx:for="{{chart.data}}" wx:for-item="d" wx:key="name">
                      <view class="pie-legend-dot" style="background: {{d.color}};" />
                      <text class="pie-legend-name">{{d.name}}</text>
                      <text class="pie-legend-val">{{d.value}}g</text>
                    </view>
                  </view>
                  <view class="pie-footer">
                    <text class="pf-item">日均 {{chart.summary.avg_calories}} 千卡</text>
                    <text class="pf-item">共 {{chart.summary.total_meals}} 餐</text>
                  </view>
                </view>

                <!-- ── dual_line: 血压 ── -->
                <view class="chart-body" wx:if="{{chart.type === 'dual_line'}}">
                  <view class="bp-latest">
                    <text class="bp-val">{{chart.summary.latest}}</text>
                    <text class="bp-unit">mmHg</text>
                  </view>
                  <view class="line-bars">
                    <view class="bar-group" wx:for="{{chart.data}}" wx:for-item="p" wx:key="label">
                      <view class="bar-pair">
                        <view class="bar sys" style="height: {{(p['收缩压'] || 0) / 2}}rpx; background: {{chart.color1}};" />
                        <view class="bar dia" style="height: {{(p['舒张压'] || 0) / 2}}rpx; background: {{chart.color2}};" />
                      </view>
                      <text class="bar-label">{{p.label}}</text>
                    </view>
                  </view>
                </view>

                <!-- ── line: PSA etc ── -->
                <view class="chart-body" wx:if="{{chart.type === 'line'}}">
                  <view class="line-bars">
                    <view class="bar-group" wx:for="{{chart.data}}" wx:for-item="p" wx:key="label">
                      <view class="bar-single" style="height: {{p.value * 20}}rpx; background: {{chart.color || '#2D8B6F'}};" />
                      <text class="bar-label">{{p.label}}</text>
                    </view>
                  </view>
                </view>

                <!-- ── adherence: 用药 ── -->
                <view class="chart-body" wx:if="{{chart.type === 'adherence'}}">
                  <view class="adh-ring-row">
                    <view class="adh-ring" style="background: conic-gradient(var(--primary) 0% {{chart.summary.overall_rate}}%, var(--border) {{chart.summary.overall_rate}}% 100%);">
                      <view class="adh-ring-center">
                        <text class="adh-pct">{{chart.summary.overall_rate}}%</text>
                      </view>
                    </view>
                    <view class="adh-stats">
                      <text class="adh-stat">✅ 已完成 {{chart.summary.completed}}</text>
                      <text class="adh-stat">❌ 漏服 {{chart.summary.missed}}</text>
                      <text class="adh-stat">📋 总计 {{chart.summary.total_tasks}}</text>
                    </view>
                  </view>
                  <view class="med-list" wx:if="{{chart.summary.by_medication}}">
                    <view class="med-item" wx:for="{{chart.summary.by_medication}}" wx:for-item="med" wx:key="name">
                      <text class="med-name">{{med.name}}</text>
                      <view class="med-bar-bg">
                        <view class="med-bar-fill" style="width: {{med.rate}}%; background: {{med.rate >= 80 ? '#2D8B6F' : '#F5A623'}};" />
                      </view>
                      <text class="med-ratio">{{med.done}}/{{med.total}}</text>
                    </view>
                  </view>
                </view>

                <!-- ── alerts: 待处理事项 ── -->
                <view class="chart-body" wx:if="{{chart.type === 'alerts'}}">
                  <view class="alert-item" wx:for="{{chart.data}}" wx:for-item="a" wx:key="title">
                    <text class="alert-icon">
                      {{a.type === 'med_low_stock' ? '💊' : a.type === 'insurance_expiry' ? '🛡️' : a.type === 'checkup_due' ? '📊' : '⚠️'}}
                    </text>
                    <view class="alert-info">
                      <text class="alert-title">{{a.title}}</text>
                      <text class="alert-desc">{{a.description}}</text>
                    </view>
                  </view>
                </view>

                <!-- ── insurance: 保险概览 ── -->
                <view class="chart-body" wx:if="{{chart.type === 'insurance'}}">
                  <view class="ins-item" wx:for="{{chart.data}}" wx:for-item="ins" wx:key="provider">
                    <view class="ins-header-row">
                      <text class="ins-name">{{ins.provider}} {{ins.policy_type}}</text>
                      <text class="ins-urgent" wx:if="{{ins.urgent}}">即将到期</text>
                    </view>
                    <text class="ins-detail" wx:if="{{ins.days_left !== null}}">
                      到期日 {{ins.end_date}} · 还剩 {{ins.days_left}} 天
                    </text>
                  </view>
                </view>

                <!-- Chart AI summary -->
                <view class="chart-ai-tip" wx:if="{{chart.summary.text}}">
                  <text class="tip-icon">🤖</text>
                  <text class="tip-text">{{chart.summary.text}}</text>
                </view>
              </view>
            </block>

            <!-- Text bubble -->
            <view class="ai-bubble" wx:if="{{item.text}}">
              <text class="ai-bubble-text">{{item.text}}</text>
            </view>
          </view>
        </view>

      </view>
    </block>

    <!-- Typing indicator -->
    <view class="msg-row assistant" wx:if="{{typing}}">
      <view class="ai-row">
        <view class="ai-avatar-sm">🤖</view>
        <view class="ai-bubble typing-bubble">
          <view class="typing-dots">
            <view class="dot-anim" />
            <view class="dot-anim" />
            <view class="dot-anim" />
          </view>
        </view>
      </view>
    </view>

    <!-- ★ Follow-up prompts — 改为 wrap 多排布局（Problem 5） -->
    <view class="followup-area" wx:if="{{messages.length > 0 && !typing}}">
      <view class="followup-wrap">
        <view
          class="followup-chip"
          wx:for="{{followupPrompts}}"
          wx:key="text"
          data-text="{{item.text}}"
          bindtap="onPromptTap"
        >
          <text>{{item.icon}} {{item.text}}</text>
        </view>
      </view>
    </view>

    <view class="scroll-bottom" id="scroll-bottom" />
  </scroll-view>

  <!-- ── Input Bar（★ Problem 4: 修复位置） ── -->
  <view class="input-bar">
    <view class="input-wrap">
      <input
        class="input-field"
        value="{{inputText}}"
        bindinput="onInputChange"
        bindconfirm="onInputConfirm"
        placeholder="{{placeholder}}"
        confirm-type="send"
        adjust-position="{{true}}"
      />
    </view>
    <view class="send-btn {{inputText.length > 0 ? 'active' : ''}}" bindtap="onInputConfirm">
      <text class="send-arrow">➤</text>
    </view>
  </view>
</view>
