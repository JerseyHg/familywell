<view class="chat-page">

  <!-- ★ Fix 1: safe-area 顶部留白 -->
  <view class="safe-top" />

  <!-- ── Header ── -->
  <view class="chat-header">
    <view class="chat-header-inner">
      <view class="chat-title-row">
        <text class="chat-title">🤖 AI 健康助手</text>
        <view class="new-chat-btn" bindtap="onNewChat">新对话</view>
      </view>
        <text class="chat-subtitle">基于你的真实健康档案回答</text>
        <view class="ai-disclaimer-badge">🤖 AI 生成内容仅供参考，不构成医疗建议</view>
    </view>
  </view>

  <!-- ── Message List ── -->
  <scroll-view
    class="message-area"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    enhanced
    bounces
    show-scrollbar="{{false}}"
  >

    <!-- Welcome -->
    <view class="welcome" wx:if="{{messages.length === 0 && !typing}}">
      <view class="welcome-avatar">🤖</view>
      <text class="welcome-title">你好，我是健康助手</text>
      <text class="welcome-desc">我能看到全部健康档案，随时可以问我</text>

      <view class="welcome-prompts">
        <view
          class="welcome-prompt"
          wx:for="{{homePrompts}}"
          wx:key="text"
          data-text="{{item.text}}"
          bindtap="onPromptTap"
        >
          <text class="wp-icon">{{item.icon}}</text>
          <text class="wp-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- Messages -->
    <block wx:for="{{messages}}" wx:key="id">
      <view id="msg-{{index}}" class="msg-row {{item.role}}">

        <!-- User bubble -->
        <view class="user-bubble" wx:if="{{item.role === 'user'}}">
          <text>{{item.text}}</text>
        </view>

        <!-- Assistant bubble -->
        <view class="ai-row" wx:if="{{item.role === 'assistant'}}">
          <view class="ai-avatar-sm">🤖</view>
          <view class="ai-bubble-group">

            <!-- Text bubble -->
            <view class="ai-bubble" wx:if="{{item.text}}">
              <text class="ai-bubble-text">{{item.text}}</text>
            </view>

            <!-- ★ 图表渲染模板 -->
            <block wx:for="{{item.charts}}" wx:for-item="chart" wx:for-index="ci" wx:key="ci">
              <view class="chart-card">
                <view class="chart-header">
                  <text class="chart-icon">{{chart.icon || '📊'}}</text>
                  <text class="chart-title">{{chart.title}}</text>
                </view>

                <!-- bar_stack → 堆叠柱形图 -->
                <view class="chart-body" wx:if="{{chart.type === 'bar_stack'}}">
                  <view class="stack-chart">
                    <view class="stack-col" wx:for="{{chart.data}}" wx:for-item="d" wx:key="label">
                      <view class="stack-bars">
                        <view wx:for="{{chart.keys}}" wx:for-item="k" wx:for-index="ki" wx:key="k"
                          class="stack-seg"
                          style="height: {{d[k] / 4}}rpx; background: {{chart.colors[ki]}};"
                        />
                      </view>
                      <text class="stack-label">{{d.label}}</text>
                    </view>
                  </view>
                  <view class="stack-legend" wx:if="{{chart.keys.length > 1}}">
                    <view class="stack-legend-item" wx:for="{{chart.keys}}" wx:for-item="k" wx:for-index="ki" wx:key="k">
                      <view class="stack-legend-dot" style="background: {{chart.colors[ki]}};" />
                      <text class="stack-legend-text">{{k}}</text>
                    </view>
                  </view>
                </view>

                <!-- line → 水平条形图 -->
                <view class="chart-body" wx:if="{{chart.type === 'line'}}">
                  <view class="hbar-chart">
                    <view class="hbar-row" wx:for="{{chart.data}}" wx:for-item="d" wx:key="label">
                      <text class="hbar-label">{{d.label}}</text>
                      <view class="hbar-track">
                        <view class="hbar-fill" style="width: {{d.pct || 50}}%; background: linear-gradient(90deg, {{chart.colors[0] || '#2D8B6F'}}, {{chart.colors[0] || '#4DB892'}});" />
                      </view>
                      <text class="hbar-value">{{d.value}}{{chart.unit || ''}}</text>
                    </view>
                  </view>
                </view>

                <!-- dual_line → 双值趋势图（血压等） -->
                <view class="chart-body" wx:if="{{chart.type === 'dual_line'}}">
                  <view class="dual-legend">
                    <view class="dual-legend-item">
                      <view class="dual-legend-dot" style="background: {{chart.color1 || '#E85D3A'}};" />
                      <text class="dual-legend-text">{{chart.key1Name}}</text>
                    </view>
                    <view class="dual-legend-item">
                      <view class="dual-legend-dot" style="background: {{chart.color2 || '#3B7DD8'}};" />
                      <text class="dual-legend-text">{{chart.key2Name}}</text>
                    </view>
                  </view>
                  <view class="dual-row" wx:for="{{chart.data}}" wx:for-item="d" wx:key="label">
                    <text class="dual-date">{{d.label}}</text>
                    <view class="dual-vals">
                      <view class="dual-bar-group">
                        <view class="dual-bar-track">
                          <view class="dual-bar-fill" style="width: {{d.pct1}}%; background: {{chart.color1 || '#E85D3A'}};" />
                        </view>
                        <text class="dual-bar-val" style="color: {{chart.color1 || '#E85D3A'}};">{{d.val1}}</text>
                      </view>
                      <view class="dual-bar-group">
                        <view class="dual-bar-track">
                          <view class="dual-bar-fill" style="width: {{d.pct2}}%; background: {{chart.color2 || '#3B7DD8'}};" />
                        </view>
                        <text class="dual-bar-val" style="color: {{chart.color2 || '#3B7DD8'}};">{{d.val2}}</text>
                      </view>
                    </view>
                  </view>
                </view>

                <!-- donut → 环形图 -->
                <view class="chart-body" wx:if="{{chart.type === 'donut'}}">
                  <view class="pie-visual">
                    <view class="pie-ring" style="background: conic-gradient({{chart.conicGradient}});">
                      <view class="pie-ring-hole">
                        <text class="pie-total-val">{{chart.total}}</text>
                        <text class="pie-total-unit">{{chart.unit || ''}}</text>
                      </view>
                    </view>
                    <view class="pie-legend">
                      <view class="pie-legend-row" wx:for="{{chart.data}}" wx:for-item="d" wx:for-index="di" wx:key="label">
                        <view class="pie-legend-dot" style="background: {{d.color}};" />
                        <text class="pie-legend-name">{{d.label}}</text>
                        <text class="pie-legend-g">{{d.value}}{{chart.unit || ''}}</text>
                        <text class="pie-legend-pct">{{d.pct}}%</text>
                      </view>
                    </view>
                  </view>
                </view>

                <!-- pie → 营养环形图 -->
                <view class="chart-body" wx:if="{{chart.type === 'pie'}}">
                  <view class="pie-visual">
                    <view class="pie-ring" style="background: conic-gradient({{chart.conicGradient}});">
                      <view class="pie-ring-hole">
                        <text class="pie-total-val">{{chart.total}}</text>
                        <text class="pie-total-unit">g</text>
                      </view>
                    </view>
                    <view class="pie-legend">
                      <view class="pie-legend-row" wx:for="{{chart.data}}" wx:for-item="d" wx:key="name">
                        <view class="pie-legend-dot" style="background: {{d.color}};" />
                        <text class="pie-legend-name">{{d.name}}</text>
                        <text class="pie-legend-g">{{d.value}}g</text>
                        <text class="pie-legend-pct">{{d.pct}}%</text>
                      </view>
                    </view>
                  </view>
                </view>

                <!-- indicator_card → 指标卡片 -->
                <view class="chart-body" wx:if="{{chart.type === 'indicator_card'}}">
                  <view class="ind-grid-v2">
                    <view class="ind-card-v2 {{d.status}}" wx:for="{{chart.data}}" wx:for-item="d" wx:key="label">
                      <view class="ind-dot-v2 {{d.status}}" />
                      <text class="ind-val-v2" style="color: {{d.status === 'danger' ? '#E55B5B' : d.status === 'warning' ? '#F5A623' : '#2D8B6F'}};">{{d.value}}</text>
                      <text class="ind-unit-v2">{{d.unit || ''}}</text>
                      <text class="ind-label-v2">{{d.label}}</text>
                    </view>
                  </view>
                </view>

                <!-- med_adherence → 用药依从性 -->
                <view class="chart-body" wx:if="{{chart.type === 'med_adherence'}}">
                  <view class="med-item" wx:for="{{chart.data}}" wx:for-item="med" wx:key="name">
                    <view class="med-top-row">
                      <text class="med-name-v2">{{med.name}}</text>
                      <view class="med-badge {{med.pct >= 80 ? 'good' : 'warn'}}">
                        <text>{{med.pct >= 90 ? '优秀' : med.pct >= 80 ? '良好' : '待改善'}}</text>
                      </view>
                    </view>
                    <view class="med-bar-row">
                      <view class="med-bar-bg-v2">
                        <view class="med-bar-fill-v2" style="width: {{med.pct}}%; background: linear-gradient(90deg, {{med.pct >= 80 ? '#2D8B6F' : '#F5A623'}}, {{med.pct >= 80 ? '#4DB892' : '#F7C948'}});" />
                      </view>
                      <text class="med-pct-v2">{{med.pct}}%</text>
                    </view>
                    <text class="med-detail-v2">已完成 {{med.done}}/{{med.total}} 次</text>
                  </view>
                </view>

                <!-- alerts → 提醒卡片 -->
                <view class="chart-body" wx:if="{{chart.type === 'alerts'}}">
                  <view class="alert-card" wx:for="{{chart.data}}" wx:for-item="a" wx:key="title">
                    <view class="alert-icon-wrap {{a.type === 'med_low_stock' ? 'med' : a.type === 'insurance_expiry' ? 'ins' : a.type === 'checkup_due' ? 'check' : 'other'}}">
                      <text class="alert-icon-v2">{{a.type === 'med_low_stock' ? '💊' : a.type === 'insurance_expiry' ? '🛡️' : a.type === 'checkup_due' ? '📊' : '⚠️'}}</text>
                    </view>
                    <view class="alert-content">
                      <text class="alert-title-v2">{{a.title}}</text>
                      <text class="alert-desc-v2">{{a.description}}</text>
                    </view>
                  </view>
                </view>

                <!-- insurance → 保险信息 -->
                <view class="chart-body" wx:if="{{chart.type === 'insurance'}}">
                  <view class="ins-card" wx:for="{{chart.data}}" wx:for-item="ins" wx:key="provider">
                    <view class="ins-top-row">
                      <text class="ins-provider">{{ins.provider}} · {{ins.policy_type}}</text>
                      <view class="ins-urgent-badge" wx:if="{{ins.urgent}}">即将到期</view>
                    </view>
                    <view class="ins-bottom-row" wx:if="{{ins.days_left !== null}}">
                      <text class="ins-date">到期 {{ins.end_date}}</text>
                      <text class="ins-days {{ins.urgent ? 'urgent' : ''}}">还剩 {{ins.days_left}} 天</text>
                    </view>
                  </view>
                </view>

                <!-- Chart AI summary -->
                <view class="chart-ai-tip" wx:if="{{chart.summary.text}}">
                  <text class="tip-icon">🤖</text>
                  <text class="tip-text">{{chart.summary.text}}</text>
                </view>
              </view>
            </block>

            <!-- ★ AI 免责声明 -->
            <view class="ai-disclaimer" wx:if="{{item.text}}">
              <text class="disclaimer-text">AI 生成内容仅供参考，如有健康问题请咨询医生</text>
            </view>
          </view>
        </view>

      </view>
    </block>

    <!-- Typing indicator -->
    <view class="msg-row assistant" wx:if="{{typing && (messages.length === 0 || !messages[messages.length - 1].text)}}">
      <view class="ai-row">
        <view class="ai-avatar-sm">🤖</view>
        <view class="ai-bubble typing-bubble">
          <view class="typing-dots">
            <view class="dot-anim" /><view class="dot-anim" /><view class="dot-anim" />
          </view>
        </view>
      </view>
    </view>

    <!-- Follow-up prompts -->
    <view class="followup-area" wx:if="{{messages.length > 0 && !typing}}">
      <view class="followup-wrap">
        <view
          class="followup-chip"
          wx:for="{{followupPrompts}}"
          wx:key="text"
          data-text="{{item.text}}"
          bindtap="onPromptTap"
        >
          <text>{{item.icon}} {{item.text}}</text>
        </view>
      </view>
    </view>

    <view class="scroll-bottom" id="scroll-bottom" />
  </scroll-view>

  <!-- ══════════════════════════════════════
       ★ 输入栏：语音输入为主，文字输入为辅
       ══════════════════════════════════════ -->
  <view class="input-bar">
    <!-- 切换模式按钮 -->
    <view class="mode-toggle" bindtap="onToggleInputMode">
      <text wx:if="{{inputMode === 'voice'}}">⌨️</text>
      <text wx:else>🎙️</text>
    </view>

    <!-- 文字输入模式 -->
    <block wx:if="{{inputMode === 'text'}}">
      <view class="input-wrap">
        <input
          class="input-field"
          value="{{inputText}}"
          bindinput="onInputChange"
          bindconfirm="onInputConfirm"
          placeholder="{{placeholder}}"
          confirm-type="send"
          adjust-position="{{true}}"
        />
      </view>
      <view class="send-btn {{inputText.length > 0 ? 'active' : ''}}" bindtap="onInputConfirm">
        <text class="send-arrow">➤</text>
      </view>
    </block>

    <!-- ★ 语音输入模式 -->
    <block wx:if="{{inputMode === 'voice'}}">
      <view
        class="voice-input-btn {{isRecording ? 'recording' : ''}}"
        catchtouchstart="onVoiceRecordStart"
        catchtouchend="onVoiceRecordEnd"
        catchtouchcancel="onVoiceRecordEnd"
      >
        <block wx:if="{{isRecording}}">
          <view class="voice-recording-wave">
            <view class="v-wave-bar" wx:for="{{[1,2,3,4,5,4,3,2,1]}}" wx:key="*this" style="animation-delay: {{index * 0.08}}s;" />
          </view>
          <text class="voice-input-label recording">松开发送 · {{recordingDuration}}s</text>
        </block>
        <block wx:else>
          <text class="voice-input-icon">🎙️</text>
          <text class="voice-input-label">按住说话</text>
        </block>
      </view>
    </block>
  </view>

</view>
