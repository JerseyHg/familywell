<view class="chat-page">

  <!-- ★ Fix 1: safe-area 顶部留白 -->
  <view class="safe-top" />

  <!-- ── Header ── -->
  <view class="chat-header">
    <view class="chat-header-inner">
      <view class="chat-title-row">
        <text class="chat-title">🤖 AI 健康助手</text>
        <view class="new-chat-btn" bindtap="onNewChat">新对话</view>
      </view>
        <text class="chat-subtitle">基于你的真实健康档案回答</text>
        <view class="ai-disclaimer-badge">🤖 AI 生成内容仅供参考，不构成医疗建议</view>
    </view>
  </view>

  <!-- ── Message List ── -->
  <scroll-view
    class="message-area"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    enhanced
    bounces
    show-scrollbar="{{false}}"
  >

    <!-- Welcome -->
    <view class="welcome" wx:if="{{messages.length === 0 && !typing}}">
      <view class="welcome-avatar">🤖</view>
      <text class="welcome-title">你好，我是健康助手</text>
      <text class="welcome-desc">我能看到全部健康档案，随时可以问我</text>

      <view class="welcome-prompts">
        <view
          class="welcome-prompt"
          wx:for="{{homePrompts}}"
          wx:key="text"
          data-text="{{item.text}}"
          bindtap="onPromptTap"
        >
          <text class="wp-icon">{{item.icon}}</text>
          <text class="wp-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- Messages -->
    <block wx:for="{{messages}}" wx:key="id">
      <view id="msg-{{index}}" class="msg-row {{item.role}}">

        <!-- User bubble -->
        <view class="user-bubble" wx:if="{{item.role === 'user'}}">
          <!-- 如果是语音消息，显示语音图标 -->
          <view class="voice-msg-indicator" wx:if="{{item.isVoice}}">
            <text class="voice-msg-icon">🎙️</text>
            <text>语音提问</text>
          </view>
          <text wx:else>{{item.text}}</text>
        </view>

        <!-- Assistant bubble -->
        <view class="ai-row" wx:if="{{item.role === 'assistant'}}">
          <view class="ai-avatar-sm">🤖</view>
          <view class="ai-bubble-group">

            <!-- Text bubble -->
            <view class="ai-bubble" wx:if="{{item.text}}">
              <text class="ai-bubble-text">{{item.text}}</text>
            </view>

            <!-- ★ 图表渲染模板 -->
            <block wx:for="{{item.charts}}" wx:for-item="chart" wx:for-index="ci" wx:key="ci">
              <view class="chart-card">
                <view class="chart-header">
                  <text class="chart-icon">{{chart.icon || '📊'}}</text>
                  <text class="chart-title">{{chart.title}}</text>
                </view>

                <!-- bar_stack -->
                <view class="chart-body" wx:if="{{chart.type === 'bar_stack'}}">
                  <view class="bar-row">
                    <view class="bar-col" wx:for="{{chart.data}}" wx:for-item="d" wx:key="label">
                      <view class="bar-stack">
                        <view wx:for="{{chart.keys}}" wx:for-item="k" wx:for-index="ki" wx:key="k"
                          class="bar-seg"
                          style="height: {{d[k] / 4}}rpx; background: {{chart.colors[ki]}};"
                        />
                      </view>
                      <text class="bar-label">{{d.label}}</text>
                    </view>
                  </view>
                  <view class="chart-legend" wx:if="{{chart.keys.length > 1}}">
                    <view class="legend-item" wx:for="{{chart.keys}}" wx:for-item="k" wx:for-index="ki" wx:key="k">
                      <view class="legend-dot" style="background: {{chart.colors[ki]}};" />
                      <text class="legend-text">{{k}}</text>
                    </view>
                  </view>
                </view>

                <!-- line -->
                <view class="chart-body" wx:if="{{chart.type === 'line'}}">
                  <view class="line-chart">
                    <view class="line-row" wx:for="{{chart.data}}" wx:for-item="d" wx:key="label">
                      <text class="line-label">{{d.label}}</text>
                      <view class="line-bar-bg">
                        <view class="line-bar-fill" style="width: {{d.pct || 50}}%; background: {{chart.colors[0] || '#2D8B6F'}};" />
                      </view>
                      <text class="line-value">{{d.value}}{{chart.unit || ''}}</text>
                    </view>
                  </view>
                </view>

                <!-- donut -->
                <view class="chart-body" wx:if="{{chart.type === 'donut'}}">
                  <view class="donut-list">
                    <view class="donut-item" wx:for="{{chart.data}}" wx:for-item="d" wx:for-index="di" wx:key="label">
                      <view class="donut-color" style="background: {{chart.colors[di % chart.colors.length]}};" />
                      <text class="donut-label">{{d.label}}</text>
                      <text class="donut-value">{{d.value}}{{chart.unit || ''}} ({{d.pct || '—'}}%)</text>
                    </view>
                  </view>
                </view>

                <!-- indicator_card -->
                <view class="chart-body" wx:if="{{chart.type === 'indicator_card'}}">
                  <view class="ind-grid">
                    <view class="ind-item" wx:for="{{chart.data}}" wx:for-item="d" wx:key="label">
                      <text class="ind-value" style="color: {{d.status === 'danger' ? '#E55B5B' : d.status === 'warning' ? '#F5A623' : '#2D8B6F'}};">{{d.value}}{{d.unit || ''}}</text>
                      <text class="ind-label">{{d.label}}</text>
                    </view>
                  </view>
                </view>

                <!-- med_adherence -->
                <view class="chart-body" wx:if="{{chart.type === 'med_adherence'}}">
                  <view class="med-row" wx:for="{{chart.data}}" wx:for-item="med" wx:key="name">
                    <text class="med-name">{{med.name}}</text>
                    <view class="med-bar-bg">
                      <view class="med-bar-fill" style="width: {{med.pct}}%; background: {{med.pct >= 80 ? '#2D8B6F' : '#F5A623'}};" />
                    </view>
                    <text class="med-ratio">{{med.done}}/{{med.total}}</text>
                  </view>
                </view>

                <!-- alerts -->
                <view class="chart-body" wx:if="{{chart.type === 'alerts'}}">
                  <view class="alert-item" wx:for="{{chart.data}}" wx:for-item="a" wx:key="title">
                    <text class="alert-icon">{{a.type === 'med_low_stock' ? '💊' : a.type === 'insurance_expiry' ? '🛡️' : a.type === 'checkup_due' ? '📊' : '⚠️'}}</text>
                    <view class="alert-info">
                      <text class="alert-title">{{a.title}}</text>
                      <text class="alert-desc">{{a.description}}</text>
                    </view>
                  </view>
                </view>

                <!-- insurance -->
                <view class="chart-body" wx:if="{{chart.type === 'insurance'}}">
                  <view class="ins-item" wx:for="{{chart.data}}" wx:for-item="ins" wx:key="provider">
                    <view class="ins-header-row">
                      <text class="ins-name">{{ins.provider}} {{ins.policy_type}}</text>
                      <text class="ins-urgent" wx:if="{{ins.urgent}}">即将到期</text>
                    </view>
                    <text class="ins-detail" wx:if="{{ins.days_left !== null}}">到期日 {{ins.end_date}} · 还剩 {{ins.days_left}} 天</text>
                  </view>
                </view>

                <!-- Chart AI summary -->
                <view class="chart-ai-tip" wx:if="{{chart.summary.text}}">
                  <text class="tip-icon">🤖</text>
                  <text class="tip-text">{{chart.summary.text}}</text>
                </view>
              </view>
            </block>

            <!-- ★ AI 免责声明 -->
            <view class="ai-disclaimer" wx:if="{{item.text}}">
              <text class="disclaimer-text">AI 生成内容仅供参考，如有健康问题请咨询医生</text>
            </view>
          </view>
        </view>

      </view>
    </block>

    <!-- Typing indicator -->
    <view class="msg-row assistant" wx:if="{{typing && !messages[messages.length - 1].text}}">
      <view class="ai-row">
        <view class="ai-avatar-sm">🤖</view>
        <view class="ai-bubble typing-bubble">
          <view class="typing-dots">
            <view class="dot-anim" /><view class="dot-anim" /><view class="dot-anim" />
          </view>
        </view>
      </view>
    </view>

    <!-- Follow-up prompts -->
    <view class="followup-area" wx:if="{{messages.length > 0 && !typing}}">
      <view class="followup-wrap">
        <view
          class="followup-chip"
          wx:for="{{followupPrompts}}"
          wx:key="text"
          data-text="{{item.text}}"
          bindtap="onPromptTap"
        >
          <text>{{item.icon}} {{item.text}}</text>
        </view>
      </view>
    </view>

    <view class="scroll-bottom" id="scroll-bottom" />
  </scroll-view>

  <!-- ══════════════════════════════════════
       ★ 输入栏：语音输入为主，文字输入为辅
       ══════════════════════════════════════ -->
  <view class="input-bar">
    <!-- 切换模式按钮 -->
    <view class="mode-toggle" bindtap="onToggleInputMode">
      <text wx:if="{{inputMode === 'voice'}}">⌨️</text>
      <text wx:else>🎙️</text>
    </view>

    <!-- 文字输入模式 -->
    <block wx:if="{{inputMode === 'text'}}">
      <view class="input-wrap">
        <input
          class="input-field"
          value="{{inputText}}"
          bindinput="onInputChange"
          bindconfirm="onInputConfirm"
          placeholder="{{placeholder}}"
          confirm-type="send"
          adjust-position="{{true}}"
        />
      </view>
      <view class="send-btn {{inputText.length > 0 ? 'active' : ''}}" bindtap="onInputConfirm">
        <text class="send-arrow">➤</text>
      </view>
    </block>

    <!-- ★ 语音输入模式 -->
    <block wx:if="{{inputMode === 'voice'}}">
      <view
        class="voice-input-btn {{isRecording ? 'recording' : ''}}"
        catchtouchstart="onVoiceRecordStart"
        catchtouchend="onVoiceRecordEnd"
        catchtouchcancel="onVoiceRecordEnd"
      >
        <block wx:if="{{isRecording}}">
          <view class="voice-recording-wave">
            <view class="v-wave-bar" wx:for="{{[1,2,3,4,5,4,3,2,1]}}" wx:key="*this" style="animation-delay: {{index * 0.08}}s;" />
          </view>
          <text class="voice-input-label recording">松开发送 · {{recordingDuration}}s</text>
        </block>
        <block wx:else>
          <text class="voice-input-icon">🎙️</text>
          <text class="voice-input-label">按住说话</text>
        </block>
      </view>
    </block>
  </view>

</view>
