<!-- pages/home/home.wxml — 首页
  ★ 审核整改：不强制登录，左上角显示登录状态
  ★ 语音改造：去掉文字转换，直接录音→上传COS→LLM分析
-->

<!-- ── Greeting + Login Status ── -->
<view class="safe-top" />
<view class="header">
  <view class="header-top">
    <view class="login-area" bindtap="onLoginTap">
      <block wx:if="{{isLoggedIn}}">
        <view class="user-avatar-sm">{{avatarText}}</view>
        <text class="user-name">{{profile.nickname || '用户'}}</text>
      </block>
      <block wx:else>
        <view class="login-icon">👤</view>
        <text class="login-text">请登录</text>
        <text class="login-arrow">›</text>
      </block>
    </view>
  </view>
  <text class="greeting">{{greeting}}</text>
  <text class="title">{{isLoggedIn ? (profile.nickname || '我') + '的健康档案' : '家庭健康档案'}}</text>
</view>

<!-- ── Action Buttons ── -->
<view class="action-row">
  <view class="action-btn upload" bindtap="onUpload">
    <view class="ab-icon">📷</view>
    <view class="ab-text">
      <text class="ab-title">拍照上传</text>
      <text class="ab-desc">拍体检单、处方…</text>
    </view>
  </view>
  <view class="action-btn file" bindtap="onFileUpload">
    <view class="ab-icon">📎</view>
    <view class="ab-text">
      <text class="ab-title">文件上传</text>
      <text class="ab-desc">PDF、图片文件</text>
    </view>
  </view>
  <view class="action-btn voice" bindtap="onVoiceAdd">
    <view class="ab-icon">🎙️</view>
    <view class="ab-text">
      <text class="ab-title">语音记录</text>
      <text class="ab-desc">说一下用药、症状…</text>
    </view>
  </view>
</view>

<!-- ── 未登录提示卡片 ── -->
<view class="login-hint-card" wx:if="{{!isLoggedIn}}">
  <text class="login-hint-icon">🔒</text>
  <view class="login-hint-body">
    <text class="login-hint-title">登录后体验更多功能</text>
    <text class="login-hint-desc">登录后可以拍照上传、语音记录、AI问答等</text>
  </view>
  <view class="login-hint-btn" bindtap="onLoginTap">去登录</view>
</view>

<!-- ══════════════════════════════════════════
     以下内容仅登录后显示
     ══════════════════════════════════════════ -->

<!-- ── AI Tip ── -->
<view class="section" wx:if="{{isLoggedIn && aiTip}}">
  <view class="tip-card">
    <text class="tip-icon">🤖</text>
    <text class="tip-text">{{aiTip}}</text>
  </view>
</view>

<!-- ══════════════════════════════════════════
     ★ 首页仪表盘 — 可视化健康数据
     ══════════════════════════════════════════ -->

<!-- ── ⚠️ 紧急提醒横幅 ── -->
<view class="section" wx:if="{{isLoggedIn && dashAlerts.length > 0}}">
  <view class="section-header">
    <text class="section-title">⚠️ 待处理提醒</text>
  </view>
  <view class="dash-alert-card {{item.priority === 'urgent' ? 'urgent' : ''}}" wx:for="{{dashAlerts}}" wx:key="title">
    <view class="dash-alert-icon-wrap {{item.type === 'medication' ? 'med' : item.type === 'insurance' ? 'ins' : 'check'}}">
      <text class="dash-alert-icon">{{item.type === 'medication' ? '💊' : item.type === 'insurance' ? '🛡️' : item.type === 'checkup' ? '📊' : '⚠️'}}</text>
    </view>
    <view class="dash-alert-body">
      <text class="dash-alert-title">{{item.title}}</text>
      <text class="dash-alert-desc" wx:if="{{item.description}}">{{item.description}}</text>
    </view>
    <text class="dash-alert-badge" wx:if="{{item.priority === 'urgent'}}">紧急</text>
  </view>
</view>

<!-- ── 三合一仪表盘卡片行 ── -->
<view class="dash-row" wx:if="{{isLoggedIn && (dashIndicators.length > 0 || dashMedAdherence || dashNutrition)}}">

  <!-- ❤️ 健康指标 -->
  <view class="dash-mini-card" wx:if="{{dashIndicators.length > 0}}">
    <text class="dash-mini-title">❤️ 指标</text>
    <view class="dash-mini-ind" wx:for="{{dashIndicators}}" wx:key="label" wx:if="{{index < 3}}">
      <view class="dash-mini-ind-dot {{item.status}}" />
      <text class="dash-mini-ind-label">{{item.label}}</text>
      <text class="dash-mini-ind-val" style="color: {{item.status === 'danger' ? '#E55B5B' : item.status === 'warning' ? '#F5A623' : '#2D8B6F'}};">{{item.value}}</text>
    </view>
    <text class="dash-mini-more" wx:if="{{dashIndicators.length > 3}}">+{{dashIndicators.length - 3}}项</text>
  </view>

  <!-- 💊 用药依从性 -->
  <view class="dash-mini-card" wx:if="{{dashMedAdherence}}">
    <text class="dash-mini-title">💊 用药</text>
    <view class="dash-mini-ring" style="background: conic-gradient({{dashMedAdherence.rate >= 80 ? '#2D8B6F' : '#F5A623'}} 0% {{dashMedAdherence.rate}}%, var(--border, #E8E4DD) {{dashMedAdherence.rate}}% 100%);">
      <view class="dash-mini-ring-hole">
        <text class="dash-mini-ring-pct">{{dashMedAdherence.rate}}%</text>
      </view>
    </view>
    <text class="dash-mini-sub">{{dashMedAdherence.done}}/{{dashMedAdherence.total}}次</text>
  </view>

  <!-- 🍽️ 营养摄入 -->
  <view class="dash-mini-card" wx:if="{{dashNutrition}}">
    <text class="dash-mini-title">🍽️ 营养</text>
    <view class="dash-mini-pie" style="background: conic-gradient({{dashNutrition.conicGradient}});">
      <view class="dash-mini-pie-hole">
        <text class="dash-mini-pie-val">{{dashNutrition.avgCalories}}</text>
      </view>
    </view>
    <text class="dash-mini-sub">kcal/日</text>
  </view>

</view>

<!-- ── 药物建议 ── -->
<view class="section" wx:if="{{isLoggedIn && medSuggestions.length > 0}}">
  <view class="section-header">
    <text class="section-title">💊 药物待确认</text>
  </view>
  <view class="med-sug-card" wx:for="{{medSuggestions}}" wx:key="id">
    <view class="sug-info">
      <text class="sug-name">{{item.name || '未知药物'}}</text>
      <text class="sug-detail" wx:if="{{item.dosage || item.frequency}}">{{item.dosage || ''}}{{item.dosage && item.frequency ? ' · ' : ''}}{{item.frequency || ''}}</text>
    </view>
    <view class="sug-actions">
      <view class="sug-confirm" data-id="{{item.id}}" bindtap="onConfirmSuggestion">确认添加</view>
      <view class="sug-dismiss" data-id="{{item.id}}" bindtap="onDismissSuggestion">忽略</view>
    </view>
  </view>
</view>

<!-- ── Pending Tasks (Medication) ── -->
<view class="section" wx:if="{{isLoggedIn && pendingTasks.length > 0}}">
  <view class="section-header">
    <text class="section-title">💊 今日用药</text>
    <text class="section-badge" wx:if="{{alertCount > 0}}">{{alertCount}}项待处理</text>
  </view>
  <view class="task-card" wx:for="{{pendingTasks}}" wx:key="id">
    <view class="task-left">
      <text class="task-icon">{{item.completed ? '✅' : '⬜'}}</text>
      <view class="task-info">
        <text class="task-name">{{item.name}}</text>
        <text class="task-time">{{item.time}}</text>
      </view>
    </view>
    <view class="task-btn {{item.completed ? 'done' : ''}}" data-id="{{item.id}}" data-completed="{{item.completed}}" bindtap="onToggleTask">
      {{item.completed ? '已服' : '打卡'}}
    </view>
  </view>
</view>

<!-- ── Quick Prompts ── -->
<view class="section" wx:if="{{isLoggedIn}}">
  <view class="section-header">
    <text class="section-title">💡 快捷提问</text>
  </view>
  <view class="prompt-grid">
    <view class="prompt-chip" wx:for="{{prompts}}" wx:key="text" data-text="{{item.text}}" bindtap="onPromptTap">
      <text class="prompt-icon">{{item.icon}}</text>
      <text class="prompt-text">{{item.text}}</text>
    </view>
  </view>
</view>

<!-- ── Recent Activity ── -->
<view class="section" wx:if="{{isLoggedIn && recentActivity.length > 0}}">
  <view class="section-header">
    <text class="section-title">📋 最近动态</text>
  </view>
  <view class="activity-card" wx:for="{{recentActivity}}" wx:key="id" data-id="{{item.id}}" data-text="{{item._voiceText || ''}}" bindtap="{{item.ai_status === 'failed' ? 'onRetryVoice' : 'onActivityTap'}}">
    <text class="activity-icon">{{item.ai_status === 'pending' || item.ai_status === 'processing' ? '⏳' : item.ai_status === 'failed' ? '❌' : item.category === 'checkup' ? '📊' : item.category === 'prescription' ? '💊' : item.category === 'food' ? '🍽️' : item.category === 'bp_reading' ? '❤️' : '📄'}}</text>
    <view class="activity-info">
      <text class="activity-title">{{item.title}}</text>
      <text class="activity-date">{{item.date}}</text>
    </view>
    <text class="activity-status" wx:if="{{item.ai_status === 'pending' || item.ai_status === 'processing'}}">识别中...</text>
    <text class="activity-status fail" wx:if="{{item.ai_status === 'failed'}}">点击重试</text>
  </view>
</view>

<!-- ══════════════════════════════════════════
     语音弹窗 — 固定布局（改造：不转文字）
     ══════════════════════════════════════════ -->
<view class="modal-mask" wx:if="{{showVoiceModal}}" bindtap="hideVoiceModal">
  <view class="voice-modal" catchtap="noop">

    <!-- 顶部标题 -->
    <view class="vm-header">
      <text class="vm-title">🎙️ 语音记录</text>
      <view class="vm-close" bindtap="hideVoiceModal">✕</view>
    </view>

    <!-- 中间内容区：固定高度，段列表可滚动 -->
    <view class="vm-content">
      <!-- 有录音段 -->
      <scroll-view scroll-y class="vm-scroll" wx:if="{{voiceSegments.length > 0}}">
        <view class="voice-seg" wx:for="{{voiceSegments}}" wx:key="index">
          <view class="seg-left">
            <text class="seg-icon">🔊</text>
            <text class="seg-label">语音 {{index + 1}}</text>
            <text class="seg-dur">{{item.duration}}秒</text>
          </view>
          <view class="seg-remove" data-index="{{index}}" catchtap="onRemoveSegment">✕</view>
        </view>
      </scroll-view>

      <!-- 空状态 -->
      <view class="vm-empty" wx:if="{{voiceSegments.length === 0 && !isRecording}}">
        <text class="empty-hint">按住下方按钮开始录音</text>
        <text class="empty-sub">支持多段录音，分别描述不同内容</text>
      </view>
    </view>

    <!-- 底部操作区：始终固定 -->
    <view class="vm-footer">
      <!-- 录音按钮（按住说话） -->
      <view
        class="vm-record-btn {{isRecording ? 'recording' : ''}}"
        catchtouchstart="onRecordStart"
        catchtouchend="onRecordEnd"
        catchtouchcancel="onRecordEnd"
      >
        <block wx:if="{{isRecording}}">
          <view class="recording-wave">
            <view class="wave-bar" wx:for="{{[1,2,3,4,5,4,3,2,1]}}" wx:key="*this" style="animation-delay: {{index * 0.1}}s;" />
          </view>
          <text class="record-label recording">松开结束 · {{recordingDuration}}s</text>
        </block>
        <block wx:else>
          <text class="record-icon">🎙️</text>
          <text class="record-label">按住说话</text>
        </block>
      </view>

      <!-- 提交按钮 -->
      <view
        class="vm-submit-btn {{voiceSegments.length > 0 && !isRecording ? 'active' : ''}}"
        bindtap="onSubmitVoice"
      >
        <text>✨ AI 识别并记录{{voiceSegments.length > 0 ? '（' + voiceSegments.length + '段）' : ''}}</text>
      </view>
    </view>

  </view>
</view>

<!-- ══════════════════════════════════════════
     ★ 药物确认弹窗 — 收集用药详细信息
     ══════════════════════════════════════════ -->
<view class="modal-mask" wx:if="{{showMedConfirm}}" bindtap="hideMedConfirm">
  <view class="med-confirm-modal" catchtap="noop">
    <view class="vm-header">
      <text class="vm-title">确认添加药物</text>
      <view class="vm-close" bindtap="hideMedConfirm">✕</view>
    </view>

    <scroll-view scroll-y class="mc-body">
      <!-- 药名 -->
      <view class="mc-drug-name">{{medConfirmName || '未知药物'}}</view>

      <!-- 用量 -->
      <view class="mc-field">
        <text class="mc-label">用量（如"每次1片"）</text>
        <input class="mc-input" placeholder="选填" value="{{medConfirmDosage}}" bindinput="onMedConfirmDosage" />
      </view>

      <!-- 用药类型 -->
      <view class="mc-field">
        <text class="mc-label">用药类型</text>
        <view class="mc-tag-row">
          <view class="mc-tag {{medConfirmType === 'long_term' ? 'active' : ''}}" data-val="long_term" bindtap="onMedConfirmType">长期</view>
          <view class="mc-tag {{medConfirmType === 'course' ? 'active' : ''}}" data-val="course" bindtap="onMedConfirmType">疗程</view>
          <view class="mc-tag {{medConfirmType === 'temporary' ? 'active' : ''}}" data-val="temporary" bindtap="onMedConfirmType">临时</view>
        </view>
      </view>

      <!-- 服用天数（疗程/临时时显示） -->
      <view class="mc-field" wx:if="{{medConfirmType === 'course' || medConfirmType === 'temporary'}}">
        <text class="mc-label">总共服用天数</text>
        <input class="mc-input" type="number" placeholder="请输入天数" value="{{medConfirmDays}}" bindinput="onMedConfirmDays" />
      </view>

      <!-- 每天几次 -->
      <view class="mc-field">
        <text class="mc-label">每天几次</text>
        <view class="mc-tag-row">
          <view class="mc-tag {{medConfirmTimes === 1 ? 'active' : ''}}" data-val="{{1}}" bindtap="onMedConfirmTimes">每天1次</view>
          <view class="mc-tag {{medConfirmTimes === 2 ? 'active' : ''}}" data-val="{{2}}" bindtap="onMedConfirmTimes">每天2次</view>
          <view class="mc-tag {{medConfirmTimes === 3 ? 'active' : ''}}" data-val="{{3}}" bindtap="onMedConfirmTimes">每天3次</view>
        </view>
      </view>
    </scroll-view>

    <view class="mc-footer">
      <view class="mc-cancel" bindtap="hideMedConfirm">取消</view>
      <view class="mc-submit {{medConfirmSubmitting ? 'disabled' : ''}}" bindtap="onSubmitMedConfirm">
        {{medConfirmSubmitting ? '添加中...' : '确认添加'}}
      </view>
    </view>
  </view>
</view>

<view class="safe-bottom" />
