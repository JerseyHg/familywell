<!-- pages/home/home.wxml — 首页（完整版）
  ★ 新增：待确认药物建议区域
  ★ 修复：medication_log 分类图标
-->

<!-- ── Greeting ── -->
<view class="safe-top" />
<view class="header">
  <text class="greeting">{{greeting}}</text>
  <text class="title">{{profile.nickname || '我'}}的健康档案</text>
</view>

<!-- ── Action Buttons ── -->
<view class="action-row">
  <view class="action-btn upload" bindtap="onUpload">
    <view class="ab-icon">📷</view>
    <view class="ab-text">
      <text class="ab-title">拍照上传</text>
      <text class="ab-desc">体检单、处方、食物…</text>
    </view>
  </view>
  <view class="action-btn voice" bindtap="onVoiceAdd">
    <view class="ab-icon">🎙️</view>
    <view class="ab-text">
      <text class="ab-title">语音记录</text>
      <text class="ab-desc">说一下用药、症状…</text>
    </view>
  </view>
</view>

<!-- ── 语音输入弹窗 ── -->
<view class="modal-mask" wx:if="{{showVoiceModal}}" bindtap="hideVoiceModal">
  <view class="voice-modal" catchtap="noop">
    <view class="vm-header">
      <text class="vm-title">🎙️ 语音记录</text>
      <view class="vm-close" bindtap="hideVoiceModal">✕</view>
    </view>
    <view class="vm-body">
      <text class="vm-hint">说说你的情况，AI 会自动识别并分类记录</text>
      <text class="vm-example">💊 用药："医生开了氨氯地平5mg，每天一次长期吃"
🍽️ 饮食："中午吃了一碗米饭、红烧鱼、炒青菜"
❤️ 指标："今天血压 135/85，心率 72"
📝 症状："最近头疼，晚上睡不好"
🔀 混合："吃了米饭和鱼，顺便把降压药吃了"</text>

      <!-- 录音状态指示 -->
      <view class="vm-record-area">
        <textarea
          class="vm-textarea"
          placeholder="点击下方按钮录音，或直接输入文字...&#10;可多次录音，内容会自动追加"
          value="{{voiceText}}"
          bindinput="onVoiceTextInput"
          maxlength="500"
          auto-height
        />

        <!-- 录音中指示 -->
        <view class="vm-recording" wx:if="{{isRecording}}">
          <view class="recording-wave">
            <view class="wave-bar" wx:for="{{[1,2,3,4,5,4,3,2,1]}}" wx:key="*this"
              style="animation-delay: {{index * 0.1}}s; height: {{item * 12 + 20}}rpx;"
            />
          </view>
          <text class="recording-text">正在听...</text>
          <text class="recording-duration">{{recordingDuration}}s</text>
        </view>
      </view>

      <!-- 底部操作区 -->
      <view class="vm-actions">
        <!-- 录音按钮 -->
        <view
          class="vm-record-btn {{isRecording ? 'recording' : ''}}"
          catchtap="onToggleRecord"
        >
          <text class="record-icon">{{isRecording ? '⏹' : '🎙️'}}</text>
          <text class="record-label">{{isRecording ? '点击结束' : (voiceText ? '继续补充' : '点击录音')}}</text>
        </view>

        <!-- 提交按钮 -->
        <view class="vm-submit-btn {{voiceText ? 'active' : ''}}" bindtap="onSubmitVoice">
          <text>AI 识别并记录</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- ── AI 温馨提示 ── -->
<view class="ai-tip-bar" wx:if="{{aiTip}}">
  <text class="atb-icon">🌿</text>
  <text class="atb-text">{{aiTip}}</text>
</view>

<!-- ══════════════════════════════════════════
     ★ 待确认药物建议
     ══════════════════════════════════════════ -->
<view class="suggestion-section" wx:if="{{medSuggestions.length > 0}}">
  <view class="suggestion-header">
    <text class="suggestion-title">💊 发现新药物，需要你确认</text>
  </view>
  <view class="suggestion-card" wx:for="{{medSuggestions}}" wx:key="id">
    <view class="sug-info">
      <text class="sug-name">{{item.name}}</text>
      <text class="sug-detail" wx:if="{{item.dosage}}">{{item.dosage}}</text>
      <text class="sug-source">来源：{{item.created_at}} 语音记录</text>
    </view>

    <!-- 确认表单（展开时显示） -->
    <view class="sug-form" wx:if="{{item._expanded}}">
      <view class="sug-form-row">
        <text class="sfr-label">每天几次</text>
        <view class="sfr-options">
          <view class="sfr-opt {{item._times === 1 ? 'active' : ''}}" data-id="{{item.id}}" data-times="1" bindtap="onSugTimes">1次</view>
          <view class="sfr-opt {{item._times === 2 ? 'active' : ''}}" data-id="{{item.id}}" data-times="2" bindtap="onSugTimes">2次</view>
          <view class="sfr-opt {{item._times === 3 ? 'active' : ''}}" data-id="{{item.id}}" data-times="3" bindtap="onSugTimes">3次</view>
        </view>
      </view>
      <view class="sug-form-row">
        <text class="sfr-label">用药类型</text>
        <view class="sfr-options">
          <view class="sfr-opt {{item._medType === 'long_term' ? 'active' : ''}}" data-id="{{item.id}}" data-type="long_term" bindtap="onSugType">长期</view>
          <view class="sfr-opt {{item._medType === 'course' ? 'active' : ''}}" data-id="{{item.id}}" data-type="course" bindtap="onSugType">疗程</view>
          <view class="sfr-opt {{item._medType === 'temporary' ? 'active' : ''}}" data-id="{{item.id}}" data-type="temporary" bindtap="onSugType">临时</view>
        </view>
      </view>
      <view class="sug-form-row" wx:if="{{item._medType === 'course' || item._medType === 'temporary'}}">
        <text class="sfr-label">共几天</text>
        <input class="sfr-input" type="number" placeholder="天数" value="{{item._totalDays}}" data-id="{{item.id}}" bindinput="onSugDays" />
      </view>
    </view>

    <view class="sug-actions">
      <view class="sug-btn dismiss" data-id="{{item.id}}" bindtap="onDismissSuggestion">忽略</view>
      <view class="sug-btn expand" data-id="{{item.id}}" bindtap="onToggleSuggestion" wx:if="{{!item._expanded}}">设置并添加</view>
      <view class="sug-btn confirm" data-id="{{item.id}}" bindtap="onConfirmSuggestion" wx:if="{{item._expanded}}">确认添加</view>
    </view>
  </view>
</view>

<!-- ── 一切顺利 ── -->
<view class="ok-bar" wx:if="{{!pendingTasks.length && !alertCount && !medSuggestions.length}}">
  <text class="ok-icon">✅</text>
  <text class="ok-text">今日一切顺利，没有待处理事项</text>
</view>

<!-- ── Pending Med Tasks ── -->
<view class="task-card" wx:for="{{pendingTasks}}" wx:key="id">
  <view class="task-left">
    <text class="task-icon">💊</text>
    <view class="task-info">
      <text class="task-name">{{item.name}}</text>
      <text class="task-time">{{item.time}} · 今日待服</text>
    </view>
  </view>
  <view class="task-punch" data-id="{{item.id}}" bindtap="onPunchTask">打卡</view>
</view>

<!-- ── Suggested Prompts ── -->
<view class="section-label">问问 AI 助手</view>
<view class="prompts-grid">
  <view
    class="prompt-item"
    wx:for="{{prompts}}"
    wx:key="text"
    data-text="{{item.text}}"
    bindtap="onPromptTap"
  >
    <text class="prompt-icon">{{item.icon}}</text>
    <text class="prompt-text">{{item.text}}</text>
  </view>
</view>

<!-- ── Recent Activity ── -->
<view class="section-label" wx:if="{{recentActivity.length}}">最近动态</view>
<view class="activity-list">
  <view class="activity-item" wx:for="{{recentActivity}}" wx:key="id"
    data-id="{{item.id}}"
    data-text="{{item._voiceText}}"
    bindtap="{{item.ai_status === 'failed' ? 'onRetryVoice' : 'onActivityTap'}}"
  >
    <text class="activity-icon">
      {{item.category === 'lab' ? '🔬' : item.category === 'prescription' ? '📝' : item.category === 'checkup' ? '📊' : item.category === 'insurance' ? '🛡️' : item.category === 'food' ? '🍽️' : item.category === 'bp_reading' ? '❤️' : item.category === 'visit' ? '🏥' : item.category === 'medication_log' ? '💊' : '📄'}}
    </text>
    <view class="activity-info">
      <text class="activity-title">{{item.title}}</text>
      <text class="activity-date">{{item.date}}</text>
    </view>
    <view class="activity-tag {{item.ai_status === 'processing' ? 'processing' : item.ai_status === 'failed' ? 'failed' : 'done'}}">
      {{item.ai_status === 'processing' ? '处理中…' : item.ai_status === 'failed' ? '失败 · 重试' : 'AI已识别'}}
    </view>
  </view>
</view>

<view class="safe-bottom" />
