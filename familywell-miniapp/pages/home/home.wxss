/* pages/home/home.wxss — 首页样式
   ★ 审核整改：左上角登录区域
   ★ 语音弹窗：固定三段布局（header / content / footer）
   ★ 文件上传：action-row 改为三列布局
*/

page { background: var(--bg, #F4F1EB); }

.safe-top { height: calc(44px + env(safe-area-inset-top)); }
.safe-bottom { height: 180rpx; }

/* ══════════════════════════════════════
   Header + Login Area
   ══════════════════════════════════════ */

.header { padding: 20rpx 40rpx 20rpx; }

.header-top {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 16rpx;
}

.login-area {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 24rpx 10rpx 12rpx;
  background: #fff;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.login-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--border, #E8E4DD);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.login-text {
  font-size: 26rpx;
  color: var(--primary, #2D8B6F);
  font-weight: 500;
}

.login-arrow {
  font-size: 28rpx;
  color: var(--text2, #8B8680);
  margin-left: 4rpx;
}

.user-avatar-sm {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2D8B6F, #4DB892);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.user-name {
  font-size: 26rpx;
  color: var(--text, #2C2820);
  font-weight: 500;
}

.greeting { font-size: 28rpx; color: var(--text2, #8B8680); display: block; }
.title { font-size: 40rpx; font-weight: 700; color: var(--text, #2C2820); display: block; margin-top: 8rpx; }

/* ══════════════════════════════════════
   Login Hint Card (未登录提示)
   ══════════════════════════════════════ */

.login-hint-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 20rpx 32rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.login-hint-icon { font-size: 48rpx; }

.login-hint-body { flex: 1; display: flex; flex-direction: column; }

.login-hint-title { font-size: 28rpx; font-weight: 600; color: var(--text, #2C2820); }
.login-hint-desc { font-size: 22rpx; color: var(--text2, #8B8680); margin-top: 4rpx; }

.login-hint-btn {
  padding: 14rpx 32rpx;
  background: var(--primary, #2D8B6F);
  color: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

/* ══════════════════════════════════════
   ★ Action Row — 三列纵向布局
   ══════════════════════════════════════ */
.action-row { display: flex; gap: 16rpx; padding: 12rpx 32rpx; }
.action-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 8rpx;
  background: #fff; border-radius: 20rpx; padding: 28rpx 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.ab-icon { font-size: 44rpx; }
.ab-text { display: flex; flex-direction: column; align-items: center; }
.ab-title { font-size: 26rpx; font-weight: 600; color: var(--text); }
.ab-desc { font-size: 20rpx; color: var(--text2); margin-top: 2rpx; }

/* ── Sections ── */
.section { padding: 12rpx 32rpx; }
.section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16rpx;
}
.section-title { font-size: 30rpx; font-weight: 600; color: var(--text); }
.section-badge {
  font-size: 22rpx; color: #E55B5B; background: #FEE; padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ── AI Tip ── */
.tip-card {
  display: flex; gap: 16rpx; align-items: flex-start;
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.tip-icon { font-size: 28rpx; flex-shrink: 0; }
.tip-text { font-size: 26rpx; color: var(--text2); line-height: 1.5; }

/* ══════════════════════════════════════
   ★ 首页仪表盘
   ══════════════════════════════════════ */

/* ── 紧急提醒横幅 ── */
.dash-alert-card {
  display: flex; align-items: center; gap: 16rpx;
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  margin-bottom: 12rpx;
  border-left: 6rpx solid #F5A623;
}
.dash-alert-card.urgent {
  border-left-color: #E55B5B;
  background: #FFF8F6;
}
.dash-alert-icon-wrap {
  width: 56rpx; height: 56rpx; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.dash-alert-icon-wrap.med { background: rgba(155,89,182,0.1); }
.dash-alert-icon-wrap.ins { background: rgba(45,139,111,0.1); }
.dash-alert-icon-wrap.check { background: rgba(91,155,213,0.1); }
.dash-alert-icon { font-size: 28rpx; }
.dash-alert-body { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.dash-alert-title { font-size: 28rpx; font-weight: 600; color: var(--text, #2C2820); }
.dash-alert-desc { font-size: 22rpx; color: var(--text2, #8B8680); }
.dash-alert-badge {
  font-size: 20rpx; color: #E55B5B; background: #FEE;
  padding: 4rpx 14rpx; border-radius: 16rpx; flex-shrink: 0;
  font-weight: 600;
}

/* ── 健康指标仪表盘 ── */
.dash-ind-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
}
.dash-ind-card {
  flex: 1; min-width: calc(50% - 8rpx);
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  display: flex; flex-direction: column; position: relative;
  border: 2rpx solid transparent;
}
.dash-ind-card.danger {
  background: rgba(229,91,91,0.04);
  border-color: rgba(229,91,91,0.15);
}
.dash-ind-card.warning {
  background: rgba(245,166,35,0.04);
  border-color: rgba(245,166,35,0.15);
}
.dash-ind-card.normal {
  background: rgba(45,139,111,0.04);
  border-color: rgba(45,139,111,0.1);
}
.dash-ind-dot {
  position: absolute; top: 16rpx; right: 16rpx;
  width: 14rpx; height: 14rpx; border-radius: 50%;
}
.dash-ind-dot.danger { background: #E55B5B; }
.dash-ind-dot.warning { background: #F5A623; }
.dash-ind-dot.normal { background: #2D8B6F; }
.dash-ind-val {
  font-size: 44rpx; font-weight: 700; line-height: 1.2;
}
.dash-ind-unit {
  font-size: 22rpx; color: var(--text2, #8B8680); margin-top: 2rpx;
}
.dash-ind-label {
  font-size: 24rpx; color: var(--text2, #8B8680); margin-top: 8rpx;
  font-weight: 500;
}

/* ── 用药依从性环形图 ── */
.dash-adh-card {
  background: #fff; border-radius: 16rpx; padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.dash-adh-top {
  display: flex; align-items: center; gap: 32rpx;
}
.dash-adh-ring {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.dash-adh-ring-hole {
  width: 110rpx; height: 110rpx; border-radius: 50%;
  background: #fff;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.dash-adh-pct {
  font-size: 36rpx; font-weight: 700; color: var(--text, #2C2820);
  line-height: 1.2;
}
.dash-adh-sub {
  font-size: 20rpx; color: var(--text2, #8B8680);
}
.dash-adh-summary {
  display: flex; flex-direction: column; gap: 12rpx;
}
.dash-adh-stat {
  font-size: 28rpx; color: var(--text, #2C2820); font-weight: 500;
}
.dash-adh-badge {
  display: inline-flex; padding: 6rpx 20rpx; border-radius: 20rpx;
  font-size: 22rpx; font-weight: 600; align-self: flex-start;
}
.dash-adh-badge.good { background: rgba(45,139,111,0.1); color: #2D8B6F; }
.dash-adh-badge.warn { background: rgba(245,166,35,0.1); color: #F5A623; }

.dash-adh-meds {
  margin-top: 24rpx; padding-top: 20rpx;
  border-top: 1rpx solid var(--border, #E8E4DD);
  display: flex; flex-direction: column; gap: 16rpx;
}
.dash-adh-med-item {
  display: flex; flex-direction: column; gap: 8rpx;
}
.dash-adh-med-name {
  font-size: 24rpx; color: var(--text, #2C2820); font-weight: 500;
}
.dash-adh-med-bar-wrap {
  display: flex; align-items: center; gap: 12rpx;
}
.dash-adh-med-bar-bg {
  flex: 1; height: 16rpx; background: var(--bg, #F4F1EB);
  border-radius: 8rpx; overflow: hidden;
}
.dash-adh-med-bar-fill {
  height: 100%; border-radius: 8rpx;
  transition: width 0.8s ease;
}
.dash-adh-med-pct {
  font-size: 22rpx; color: var(--text2, #8B8680); min-width: 60rpx;
  text-align: right;
}

/* ── 营养摄入饼图 ── */
.dash-nutri-card {
  background: #fff; border-radius: 16rpx; padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.dash-nutri-visual {
  display: flex; align-items: center; gap: 32rpx;
}
.dash-nutri-pie {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.dash-nutri-pie-hole {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: #fff;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.dash-nutri-cal-val {
  font-size: 28rpx; font-weight: 700; color: var(--text, #2C2820);
  line-height: 1.2;
}
.dash-nutri-cal-unit {
  font-size: 18rpx; color: var(--text2, #8B8680);
}
.dash-nutri-legend {
  flex: 1; display: flex; flex-direction: column; gap: 16rpx;
}
.dash-nutri-legend-row {
  display: flex; align-items: center; gap: 10rpx;
}
.dash-nutri-legend-dot {
  width: 16rpx; height: 16rpx; border-radius: 4rpx; flex-shrink: 0;
}
.dash-nutri-legend-name {
  font-size: 26rpx; color: var(--text, #2C2820); flex: 1;
}
.dash-nutri-legend-val {
  font-size: 26rpx; color: var(--text2, #8B8680); font-weight: 500;
}
.dash-nutri-footer {
  display: block; text-align: center; margin-top: 16rpx;
  font-size: 22rpx; color: var(--text2, #8B8680);
}

/* ── Med Suggestions ── */
.med-sug-card {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  margin-bottom: 12rpx;
}
.sug-info { margin-bottom: 16rpx; }
.sug-name { font-size: 30rpx; font-weight: 600; color: var(--text); display: block; }
.sug-detail { font-size: 24rpx; color: var(--text2); display: block; margin-top: 4rpx; }
.sug-actions { display: flex; gap: 16rpx; }
.sug-confirm {
  flex: 1; text-align: center; padding: 16rpx 0;
  background: var(--primary, #2D8B6F); color: #fff;
  border-radius: 12rpx; font-size: 26rpx; font-weight: 600;
}
.sug-dismiss {
  flex: 1; text-align: center; padding: 16rpx 0;
  background: var(--bg, #F4F1EB); color: var(--text2);
  border-radius: 12rpx; font-size: 26rpx;
}

/* ── Tasks ── */
.task-card {
  display: flex; align-items: center; justify-content: space-between;
  background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  margin-bottom: 12rpx;
}
.task-left { display: flex; align-items: center; gap: 16rpx; }
.task-icon { font-size: 32rpx; }
.task-info { display: flex; flex-direction: column; }
.task-name { font-size: 28rpx; font-weight: 500; color: var(--text); }
.task-time { font-size: 22rpx; color: var(--text2); }
.task-btn {
  padding: 12rpx 28rpx; border-radius: 24rpx;
  background: var(--primary, #2D8B6F); color: #fff;
  font-size: 24rpx; font-weight: 600;
}
.task-btn.done { background: var(--border, #E8E4DD); color: var(--text2); }

/* ── Prompts ── */
.prompt-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.prompt-chip {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 14rpx 24rpx; border-radius: 32rpx;
  background: #fff; border: 1rpx solid var(--border, #E8E4DD);
  font-size: 24rpx; color: var(--text2);
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
}
.prompt-icon { font-size: 24rpx; }
.prompt-text { font-size: 24rpx; }

/* ── Activity ── */
.activity-card {
  display: flex; align-items: center; gap: 16rpx;
  background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  margin-bottom: 12rpx;
}
.activity-icon { font-size: 36rpx; flex-shrink: 0; }
.activity-info { flex: 1; display: flex; flex-direction: column; }
.activity-title { font-size: 28rpx; color: var(--text); font-weight: 500; }
.activity-date { font-size: 22rpx; color: var(--text2); }
.activity-status { font-size: 22rpx; color: var(--primary, #2D8B6F); }
.activity-status.fail { color: #E55B5B; }

/* ════════════════════════════════════════
   语音弹窗 — 居中 + 三段固定布局
   ════════════════════════════════════════ */

.modal-mask {
  position: fixed; inset: 0; z-index: 999;
  background: rgba(0,0,0,0.45);
  display: flex; align-items: center; justify-content: center;
  padding: 0 32rpx;
}
.voice-modal {
  width: 100%;
  background: #fff; border-radius: 28rpx;
  display: flex; flex-direction: column;
  overflow: hidden;
}

/* ── 顶部 ── */
.vm-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 36rpx 16rpx;
  flex-shrink: 0;
}
.vm-title { font-size: 34rpx; font-weight: 700; color: var(--text); }
.vm-close {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%; background: var(--border, #E8E4DD);
  font-size: 28rpx; color: var(--text2);
}

/* ── 中间内容区：固定高度 ── */
.vm-content {
  height: 300rpx;
  padding: 0 36rpx;
  display: flex; flex-direction: column; justify-content: center;
}
.vm-scroll {
  height: 100%;
}
.voice-seg {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--bg, #F4F1EB);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}
.seg-left { display: flex; align-items: center; gap: 12rpx; }
.seg-icon { font-size: 32rpx; }
.seg-label { font-size: 28rpx; color: var(--text); font-weight: 500; }
.seg-dur { font-size: 24rpx; color: var(--text2); }
.seg-remove {
  width: 48rpx; height: 48rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%; background: rgba(0,0,0,0.06);
  font-size: 24rpx; color: var(--text2);
}

.vm-empty {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center;
  height: 100%;
}
.empty-hint { font-size: 28rpx; color: var(--text2); }
.empty-sub { font-size: 24rpx; color: var(--text2); margin-top: 8rpx; opacity: 0.7; }

/* ── 底部操作区：固定 ── */
.vm-footer {
  padding: 16rpx 36rpx 36rpx;
  display: flex; flex-direction: column; gap: 20rpx;
  flex-shrink: 0;
}

/* 录音按钮 — 波形动画在按钮内部 */
.vm-record-btn {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  width: 100%; height: 112rpx;
  border-radius: 16rpx;
  background: var(--bg, #F4F1EB);
  border: 2rpx solid var(--border, #E8E4DD);
  transition: background 0.15s;
}
.vm-record-btn:active {
  background: #E8E4DD;
}
.vm-record-btn.recording {
  background: #FEF2F2;
  border-color: #FECACA;
}

.record-icon { font-size: 40rpx; }
.record-label { font-size: 30rpx; color: var(--text); font-weight: 500; }
.record-label.recording { color: #DC2626; }

/* 波形 — 在按钮内水平排列 */
.recording-wave {
  display: flex; align-items: center; gap: 6rpx;
  height: 48rpx;
}
.wave-bar {
  width: 6rpx; height: 100%;
  border-radius: 3rpx;
  background: #DC2626;
  animation: wave-anim 0.8s ease-in-out infinite alternate;
}
@keyframes wave-anim {
  0% { transform: scaleY(0.3); }
  100% { transform: scaleY(1); }
}

/* 提交按钮 */
.vm-submit-btn {
  width: 100%; height: 96rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 16rpx;
  background: var(--border, #E8E4DD);
  color: var(--text2);
  font-size: 30rpx; font-weight: 600;
  transition: all 0.2s;
}
.vm-submit-btn.active {
  background: var(--primary, #2D8B6F);
  color: #fff;
}

/* ════════════════════════════════════════
   ★ 药物确认弹窗
   ════════════════════════════════════════ */
.med-confirm-modal {
  width: 100%;
  background: #fff; border-radius: 28rpx;
  display: flex; flex-direction: column;
  overflow: hidden;
  max-height: 80vh;
}
.mc-body {
  padding: 0 36rpx 24rpx;
  max-height: 60vh;
}
.mc-drug-name {
  font-size: 36rpx; font-weight: 700; color: var(--text, #2C2820);
  padding: 16rpx 0 24rpx; text-align: center;
}
.mc-field { margin-bottom: 24rpx; }
.mc-label {
  font-size: 26rpx; color: var(--text2, #8B8680);
  display: block; margin-bottom: 12rpx;
}
.mc-input {
  width: 100%; height: 80rpx; padding: 0 24rpx;
  border: 2rpx solid var(--border, #E8E4DD); border-radius: 12rpx;
  font-size: 28rpx; color: var(--text, #2C2820);
  box-sizing: border-box;
}
.mc-tag-row { display: flex; gap: 16rpx; flex-wrap: wrap; }
.mc-tag {
  padding: 16rpx 28rpx; border-radius: 12rpx;
  background: var(--bg, #F4F1EB); color: var(--text2, #8B8680);
  font-size: 26rpx; font-weight: 500;
  border: 2rpx solid transparent;
}
.mc-tag.active {
  background: rgba(45, 139, 111, 0.1); color: var(--primary, #2D8B6F);
  border-color: var(--primary, #2D8B6F); font-weight: 600;
}
.mc-footer {
  display: flex; gap: 16rpx;
  padding: 16rpx 36rpx 36rpx;
  flex-shrink: 0;
}
.mc-cancel {
  flex: 1; text-align: center; padding: 20rpx 0;
  background: var(--bg, #F4F1EB); color: var(--text2, #8B8680);
  border-radius: 12rpx; font-size: 28rpx;
}
.mc-submit {
  flex: 2; text-align: center; padding: 20rpx 0;
  background: var(--primary, #2D8B6F); color: #fff;
  border-radius: 12rpx; font-size: 28rpx; font-weight: 600;
}
.mc-submit.disabled { opacity: 0.6; }
