<!--
  pages/login/login.wxml — 登录页
  ★ 隐私协议 checkbox + 用户服务协议链接
-->
<view class="login-page">
  <view class="safe-top" />

  <view class="login-header">
    <text class="app-logo">🏥</text>
    <text class="app-name">FamilyWell</text>
    <text class="app-desc">家庭健康档案管理</text>
  </view>

  <!-- ═══ 微信登录模式 ═══ -->
  <view class="login-body" wx:if="{{mode === 'wechat'}}">
    <view class="wx-login-card">
      <view
        class="wx-login-btn {{!privacyAgreed ? 'disabled' : ''}}"
        bindtap="onWxLogin"
      >
        <text class="wx-icon">💬</text>
        <text class="wx-text">{{wxLoading ? '登录中...' : '微信一键登录'}}</text>
      </view>
      <text class="wx-hint">首次使用将自动创建账号</text>

      <!-- ★ 隐私协议 + 服务协议 checkbox -->
      <view class="privacy-row" catchtap="noop">
        <view class="privacy-check {{privacyAgreed ? 'checked' : ''}}" catchtap="onTogglePrivacy">
          <text wx:if="{{privacyAgreed}}">✓</text>
        </view>
        <view class="privacy-text">
          <text>我已阅读并同意</text>
          <text class="privacy-link" catchtap="goAgreement" data-type="service">《用户服务协议》</text>
          <text>和</text>
          <text class="privacy-link" catchtap="onOpenPrivacy">《隐私保护指引》</text>
        </view>
      </view>
    </view>

    <view class="switch-row">
      <text class="switch-text" bindtap="switchToAccount">使用账号密码登录 →</text>
    </view>
  </view>

  <!-- ═══ 账号密码模式 ═══ -->
  <view class="login-body" wx:if="{{mode !== 'wechat'}}">
    <view class="form-card">
      <view class="mode-tabs">
        <view
          class="mode-tab {{mode === 'account-login' ? 'active' : ''}}"
          data-mode="account-login"
          bindtap="switchMode"
        >登录</view>
        <view
          class="mode-tab {{mode === 'account-register' ? 'active' : ''}}"
          data-mode="account-register"
          bindtap="switchMode"
        >注册</view>
      </view>

      <view class="field">
        <text class="field-label">用户名</text>
        <input
          class="field-input"
          placeholder="请输入用户名"
          value="{{username}}"
          bindinput="onUsernameInput"
        />
      </view>

      <view class="field">
        <text class="field-label">密码</text>
        <input
          class="field-input"
          placeholder="请输入密码"
          password
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>

      <view class="field" wx:if="{{mode === 'account-register'}}">
        <text class="field-label">昵称</text>
        <input
          class="field-input"
          placeholder="给自己取个名字"
          value="{{nickname}}"
          bindinput="onNicknameInput"
        />
      </view>

      <!-- ★ 账号模式也要勾选隐私 + 服务协议 -->
      <view class="privacy-row" catchtap="noop">
        <view class="privacy-check {{privacyAgreed ? 'checked' : ''}}" catchtap="onTogglePrivacy">
          <text wx:if="{{privacyAgreed}}">✓</text>
        </view>
        <view class="privacy-text">
          <text>我已阅读并同意</text>
          <text class="privacy-link" catchtap="goAgreement" data-type="service">《用户服务协议》</text>
          <text>和</text>
          <text class="privacy-link" catchtap="onOpenPrivacy">《隐私保护指引》</text>
        </view>
      </view>

      <button
        class="submit-btn {{!privacyAgreed ? 'disabled' : ''}}"
        bindtap="onSubmit"
        loading="{{loading}}"
      >
        {{mode === 'account-login' ? '登录' : '注册'}}
      </button>
    </view>

    <view class="switch-row">
      <text class="switch-text" bindtap="switchToWechat">← 返回微信登录</text>
    </view>
  </view>

  <view class="safe-bottom" />
</view>
