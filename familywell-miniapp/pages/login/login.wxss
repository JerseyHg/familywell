/* pages/login/login.wxss
   ★ 新增隐私协议 checkbox 样式
*/

page { background: var(--bg); }
.safe-top { height: calc(80px + env(safe-area-inset-top)); }
.safe-bottom { height: calc(60rpx + env(safe-area-inset-bottom)); }

.login-header {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 0;
}
.app-logo { font-size: 80rpx; margin-bottom: 16rpx; }
.app-name { font-size: 48rpx; font-weight: 800; color: var(--text); }
.app-desc { font-size: 26rpx; color: var(--sub); margin-top: 8rpx; }

.login-body { padding: 0 48rpx; }

/* ── WeChat Login ── */
.wx-login-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 32rpx;
}
.wx-login-btn {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  width: 100%; padding: 28rpx;
  border-radius: 48rpx;
  background: #07C160;
  color: #fff; font-size: 32rpx; font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(7,193,96,0.3);
  transition: opacity 0.2s;
}
.wx-login-btn.disabled {
  opacity: 0.5;
  box-shadow: none;
}
.wx-icon { font-size: 40rpx; }
.wx-hint {
  margin-top: 20rpx;
  font-size: 24rpx; color: var(--muted);
}

/* ★ 隐私协议 checkbox */
.privacy-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-top: 32rpx;
}
.privacy-check {
  width: 36rpx; height: 36rpx;
  border: 3rpx solid var(--border, #D1CCC5);
  border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: transparent;
  flex-shrink: 0;
  transition: all 0.15s;
}
.privacy-check.checked {
  background: var(--primary, #2D8B6F);
  border-color: var(--primary, #2D8B6F);
  color: #fff;
}
.privacy-text {
  font-size: 24rpx; color: var(--sub, #8B8680);
  line-height: 1.4;
}
.privacy-link {
  color: var(--primary, #2D8B6F);
  font-weight: 500;
}

/* ── Mode Switch ── */
.switch-row { text-align: center; padding: 40rpx; }
.switch-text { font-size: 26rpx; color: var(--primary); }

/* ── Account Form ── */
.form-card {
  background: var(--card);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.mode-tabs {
  display: flex; gap: 0;
  background: var(--bg);
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 40rpx;
}
.mode-tab {
  flex: 1; text-align: center;
  padding: 18rpx; border-radius: 16rpx;
  font-size: 28rpx; color: var(--sub);
}
.mode-tab.active {
  background: var(--card); color: var(--text);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.field { margin-bottom: 28rpx; }
.field-label {
  display: block; font-size: 24rpx; color: var(--sub);
  margin-bottom: 10rpx; font-weight: 600;
}
.field-input {
  width: 100%; height: 88rpx; padding: 0 24rpx;
  background: var(--bg); border-radius: 20rpx;
  font-size: 30rpx; color: var(--text);
  box-sizing: border-box;
}

.submit-btn {
  width: 100% !important; margin-top: 20rpx;
  padding: 24rpx !important;
  border-radius: 48rpx !important;
  background: var(--primary) !important;
  color: #fff !important;
  font-size: 30rpx !important; font-weight: 600 !important;
  border: none !important;
  line-height: 1.5 !important;
  transition: opacity 0.2s;
}
.submit-btn.disabled {
  opacity: 0.5 !important;
}
.submit-btn::after { display: none; }
