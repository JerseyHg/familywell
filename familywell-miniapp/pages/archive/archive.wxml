<view class="safe-top" />
<view class="page-header">
  <text class="page-title">归档</text>
  <text class="page-sub">你的健康记录，按项目整理</text>
</view>

<!-- ── Tab 切换：项目 / 分类 ── -->
<view class="view-tabs">
  <view class="vtab {{viewMode === 'projects' ? 'active' : ''}}" bindtap="switchView" data-mode="projects">项目</view>
  <view class="vtab {{viewMode === 'category' ? 'active' : ''}}" bindtap="switchView" data-mode="category">分类</view>
</view>

<!-- ════ 项目视图 ════ -->
<block wx:if="{{viewMode === 'projects'}}">

  <!-- 新建项目按钮 -->
  <view class="create-project-btn" bindtap="onCreateProject">
    <text class="cpb-icon">＋</text>
    <text class="cpb-text">新建项目</text>
  </view>

  <!-- 进行中的项目 -->
  <view class="section-label" wx:if="{{activeProjects.length}}">进行中</view>
  <view class="project-list">
    <view
      class="project-card"
      wx:for="{{activeProjects}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onProjectTap"
    >
      <view class="pc-left">
        <text class="pc-icon">{{item.icon || '📁'}}</text>
        <view class="pc-info">
          <text class="pc-name">{{item.name}}</text>
          <text class="pc-meta">{{item.record_count}} 条记录 · {{item.dateRange}}</text>
        </view>
      </view>
      <text class="pc-arrow">›</text>
    </view>
  </view>

  <!-- 已结束的项目 -->
  <view class="section-label" wx:if="{{archivedProjects.length}}">已结束</view>
  <view class="project-list">
    <view
      class="project-card archived"
      wx:for="{{archivedProjects}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onProjectTap"
    >
      <view class="pc-left">
        <text class="pc-icon">{{item.icon || '📁'}}</text>
        <view class="pc-info">
          <text class="pc-name">{{item.name}}</text>
          <text class="pc-meta">{{item.record_count}} 条记录 · {{item.dateRange}}</text>
        </view>
      </view>
      <text class="pc-arrow">›</text>
    </view>
  </view>

  <!-- 未归项目的记录 -->
  <view class="section-label" wx:if="{{unassignedRecords.length}}">未归项目</view>
  <view class="record-list">
    <view class="record-item" wx:for="{{unassignedRecords}}" wx:key="id">
      <text class="ri-icon">
        {{item.category === 'lab' ? '🔬' : item.category === 'prescription' ? '📝' : item.category === 'checkup' ? '📊' : item.category === 'insurance' ? '🛡️' : item.category === 'food' ? '🍽️' : item.category === 'bp_reading' ? '❤️' : '📄'}}
      </text>
      <view class="ri-info">
        <text class="ri-title">{{item.title || '未命名'}}</text>
        <text class="ri-date">{{item.displayDate}}</text>
      </view>
      <view class="ri-tag">{{item.categoryName}}</view>
    </view>
  </view>

  <view class="empty-hint" wx:if="{{!activeProjects.length && !archivedProjects.length && !unassignedRecords.length}}">
    <text class="empty-icon">📂</text>
    <text class="empty-text">还没有记录，去首页拍照上传吧</text>
  </view>
</block>

<!-- ════ 分类视图 ════ -->
<block wx:if="{{viewMode === 'category'}}">
  <!-- 分类筛选 -->
  <scroll-view scroll-x class="cat-scroll">
    <view
      class="cat-chip {{activeCat === item.key ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onCatTap"
    >
      <text>{{item.icon}} {{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 记录列表 -->
  <view class="record-list">
    <view class="record-item" wx:for="{{catRecords}}" wx:key="id">
      <text class="ri-icon">
        {{item.category === 'lab' ? '🔬' : item.category === 'prescription' ? '📝' : item.category === 'checkup' ? '📊' : item.category === 'insurance' ? '🛡️' : item.category === 'food' ? '🍽️' : item.category === 'bp_reading' ? '❤️' : '📄'}}
      </text>
      <view class="ri-info">
        <text class="ri-title">{{item.title || '未命名'}}</text>
        <text class="ri-date">{{item.displayDate}}{{item.hospital ? ' · ' + item.hospital : ''}}</text>
      </view>
      <view class="ri-tag" wx:if="{{item.project_name}}">{{item.project_name}}</view>
    </view>
  </view>

  <view class="empty-hint" wx:if="{{!catRecords.length}}">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">该分类下暂无记录</text>
  </view>
</block>

<!-- ════ 新建项目弹窗 ════ -->
<view class="modal-mask" wx:if="{{showCreateModal}}" bindtap="hideCreateModal">
  <view class="create-modal" catchtap="">
    <view class="cm-header">
      <text class="cm-title">新建项目</text>
      <view class="cm-close" bindtap="hideCreateModal">✕</view>
    </view>

    <!-- 模板选择 -->
    <view class="cm-section">
      <text class="cm-label">选择模板</text>
      <view class="template-grid">
        <view
          class="tpl-item {{newProject.template === item.key ? 'active' : ''}}"
          wx:for="{{templates}}"
          wx:key="key"
          data-key="{{item.key}}"
          data-icon="{{item.icon}}"
          data-name="{{item.name}}"
          bindtap="onTemplateTap"
        >
          <text class="tpl-icon">{{item.icon}}</text>
          <text class="tpl-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="cm-section">
      <text class="cm-label">项目名称</text>
      <input class="cm-input" placeholder="如：第三周期化疗" value="{{newProject.name}}" bindinput="onProjectNameInput" />
    </view>

    <view class="cm-section">
      <text class="cm-label">备注（选填）</text>
      <input class="cm-input" placeholder="简要描述" value="{{newProject.description}}" bindinput="onProjectDescInput" />
    </view>

    <view class="cm-section">
      <text class="cm-label">时间范围（该时段内的记录自动归入）</text>
      <view class="cm-date-row">
        <picker mode="date" value="{{newProject.start_date}}" bindchange="onStartDateChange">
          <view class="cm-date-picker">{{newProject.start_date || '开始日期'}}</view>
        </picker>
        <text class="cm-date-sep">至</text>
        <picker mode="date" value="{{newProject.end_date}}" bindchange="onEndDateChange">
          <view class="cm-date-picker">{{newProject.end_date || '结束日期'}}</view>
        </picker>
      </view>
    </view>

    <button class="cm-submit" bindtap="onSubmitProject" loading="{{creating}}">创建项目</button>
  </view>
</view>

<view class="safe-bottom" />
