<view class="safe-top" />
<view class="page-title">设置</view>

<!-- ── Emergency Card ── -->
<view class="emergency-card" bindtap="showEmergency">
  <view class="em-deco" />
  <view class="em-badge">紧急信息卡</view>
  <view class="em-name-row">
    <text class="em-name">{{emergency.name || '未设置'}}</text>
    <text class="em-tag" wx:if="{{emergency.bloodType}}">{{emergency.bloodType}}</text>
    <text class="em-tag" wx:if="{{emergency.age}}">{{emergency.age}}岁</text>
  </view>
  <text class="em-detail" wx:if="{{emergency.allergies}}">过敏: {{emergency.allergies}}</text>
  <text class="em-detail" wx:if="{{emergency.diseases}}">疾病: {{emergency.diseases}}</text>
  <text class="em-hint">点击全屏出示给医生 →</text>
</view>

<!-- ── Emergency Modal ── -->
<view class="modal-mask" wx:if="{{showEmergencyModal}}" bindtap="hideEmergency">
  <view class="modal-body" catchtap="">
    <view class="modal-header">
      <text class="modal-title">紧急医疗信息</text>
      <view class="modal-close" bindtap="hideEmergency">✕</view>
    </view>
    <view class="modal-content">
      <view class="modal-row">
        <text class="modal-label">姓名</text>
        <text class="modal-value">{{emergency.name}}</text>
      </view>
      <view class="modal-row">
        <text class="modal-label">血型</text>
        <text class="modal-value">{{emergency.bloodType}}</text>
      </view>
      <view class="modal-row">
        <text class="modal-label">年龄</text>
        <text class="modal-value">{{emergency.age}}岁</text>
      </view>
      <view class="modal-row full">
        <text class="modal-label">过敏</text>
        <text class="modal-value">{{emergency.allergies || '无'}}</text>
      </view>
      <view class="modal-row full">
        <text class="modal-label">用药</text>
        <text class="modal-value">{{emergency.medications || '无'}}</text>
      </view>
    </view>
  </view>
</view>

<!-- ── Menu: 个人信息 ── -->
<view class="section-label">个人信息</view>
<view class="menu-group">
  <view class="menu-item" bindtap="goEditProfile" data-step="1">
    <text class="mi-icon">👤</text><text class="mi-label">个人资料</text><text class="mi-arrow">›</text>
  </view>
  <view class="menu-item" bindtap="goEditProfile" data-step="2">
    <text class="mi-icon">📋</text><text class="mi-label">既往病史</text><text class="mi-arrow">›</text>
  </view>
  <view class="menu-item" bindtap="goEditProfile" data-step="3">
    <text class="mi-icon">⚠️</text><text class="mi-label">过敏信息</text><text class="mi-arrow">›</text>
  </view>
  <view class="menu-item" bindtap="goEditProfile" data-step="4">
    <text class="mi-icon">📞</text><text class="mi-label">紧急联系人</text><text class="mi-arrow">›</text>
  </view>
</view>

<!-- ══════════════════════════════
     家庭管理
     ══════════════════════════════ -->
<view class="section-label">家庭</view>

<!-- ── 未加入家庭：显示创建/加入 ── -->
<view class="menu-group" wx:if="{{!family}}">
  <view class="menu-item" bindtap="onCreateFamily">
    <text class="mi-icon">➕</text>
    <text class="mi-label">创建家庭</text>
    <text class="mi-desc">成为管理者</text>
    <text class="mi-arrow">›</text>
  </view>
  <view class="menu-item" bindtap="onShowJoinModal">
    <text class="mi-icon">🔗</text>
    <text class="mi-label">加入家庭</text>
    <text class="mi-desc">输入邀请码</text>
    <text class="mi-arrow">›</text>
  </view>
</view>

<!-- ── 已加入家庭：显示家庭信息 ── -->
<block wx:if="{{family}}">
  <!-- 家庭卡片 -->
  <view class="family-card">
    <view class="fc-top">
      <text class="fc-icon">🏠</text>
      <view class="fc-info">
        <text class="fc-name">{{family.name}}</text>
        <text class="fc-role">{{myRole === 'admin' ? '管理者' : '成员'}}</text>
      </view>
    </view>
    <view class="fc-code-row" bindtap="copyInviteCode">
      <text class="fc-code-label">邀请码</text>
      <text class="fc-code">{{family.invite_code}}</text>
      <text class="fc-copy">复制</text>
    </view>
  </view>

  <!-- 成员列表 -->
  <view class="member-list">
    <view class="member-item" wx:for="{{familyMembers}}" wx:key="user_id">
      <view class="mb-left">
        <view class="mb-avatar">{{item.nickname ? item.nickname[0] : '?'}}</view>
        <view class="mb-info">
          <text class="mb-name">{{item.nickname || '未命名'}}</text>
          <text class="mb-role-tag {{item.role === 'admin' ? 'admin' : ''}}">{{item.role === 'admin' ? '管理者' : '成员'}}</text>
        </view>
      </view>
      <view class="mb-actions">
        <!-- admin 可查看成员概况 -->
        <text class="mb-detail" wx:if="{{myRole === 'admin'}}" catchtap="onViewMember" data-uid="{{item.user_id}}" data-name="{{item.nickname}}">查看</text>
        <!-- admin 可移除非自己的成员 -->
        <text class="mb-remove" wx:if="{{myRole === 'admin' && item.role !== 'admin'}}" catchtap="onRemoveMember" data-uid="{{item.user_id}}" data-name="{{item.nickname}}">移除</text>
      </view>
    </view>
  </view>
</block>

<!-- ── 加入家庭弹窗 ── -->
<view class="modal-mask" wx:if="{{showJoinModal}}" bindtap="hideJoinModal">
  <view class="join-modal" catchtap="noop">
    <view class="jm-header">
      <text class="jm-title">加入家庭</text>
      <view class="jm-close" bindtap="hideJoinModal">✕</view>
    </view>
    <view class="jm-body">
      <text class="jm-label">请输入邀请码</text>
      <input class="jm-input" placeholder="如 FW3K9X" maxlength="6" value="{{joinCode}}" bindinput="onJoinCodeInput" />
      <button class="jm-submit" bindtap="onSubmitJoin" loading="{{joining}}">加入</button>
    </view>
  </view>
</view>

<!-- ── Menu: 数据 ── -->
<view class="section-label">数据</view>
<view class="menu-group">
  <view class="menu-item" bindtap="goArchive">
    <text class="mi-icon">📂</text>
    <text class="mi-label">全部记录</text>
    <text class="mi-desc">{{recordCount}} 条</text>
    <text class="mi-arrow">›</text>
  </view>
  <view class="menu-item" bindtap="onExportData">
    <text class="mi-icon">📤</text><text class="mi-label">导出数据</text><text class="mi-arrow">›</text>
  </view>
</view>

<!-- ── Menu: 关于 ── -->
<view class="section-label">关于</view>
<view class="menu-group">
  <view class="menu-item" bindtap="onFeedback">
    <text class="mi-icon">❓</text><text class="mi-label">帮助与反馈</text><text class="mi-arrow">›</text>
  </view>
  <view class="menu-item" bindtap="goAgreement" data-type="service">
    <text class="mi-icon">📄</text><text class="mi-label">用户服务协议</text><text class="mi-arrow">›</text>
  </view>
  <view class="menu-item" bindtap="goAgreement" data-type="privacy">
    <text class="mi-icon">🔒</text><text class="mi-label">隐私政策</text><text class="mi-arrow">›</text>
  </view>
  <view class="menu-item" bindtap="onShowAbout">
    <text class="mi-icon">ℹ️</text><text class="mi-label">关于 FamilyWell</text>
    <text class="mi-desc">v2.0</text><text class="mi-arrow">›</text>
  </view>
</view>

<view class="logout-btn" bindtap="onLogout">退出登录</view>

<!-- ★ 账号注销 -->
<view class="delete-account-btn" bindtap="onDeleteAccount">注销账号</view>

<!-- ── 关于 FamilyWell 弹窗 ── -->
<view class="modal-mask" wx:if="{{showAboutModal}}" bindtap="hideAbout">
  <view class="about-modal" catchtap="noop">
    <view class="about-logo">🏥</view>
    <text class="about-name">FamilyWell</text>
    <text class="about-slogan">家庭健康档案管理</text>
    <view class="about-divider" />
    <view class="about-info">
      <view class="about-row">
        <text class="about-label">版本</text>
        <text class="about-value">v2.0.0</text>
      </view>
      <view class="about-row">
        <text class="about-label">开发者</text>
        <text class="about-value">FamilyWell 团队</text>
      </view>
      <view class="about-row">
        <text class="about-label">联系邮箱</text>
        <text class="about-value about-email" bindtap="copyEmail">teban.official@gmail.com</text>
      </view>
    </view>
    <view class="about-footer">
      <text class="about-copyright">© 2025 FamilyWell. All rights reserved.</text>
    </view>
  </view>
</view>

<view class="safe-bottom" />
