/* pages/settings/settings.wxss
   ★ 新增：关于 FamilyWell 弹窗样式
*/

page { background: var(--bg); }

.safe-top { height: calc(44px + env(safe-area-inset-top)); }
.page-title { padding: 16rpx 48rpx 32rpx; font-size: 48rpx; font-weight: 800; color: var(--text); }

/* Emergency Card */
.emergency-card {
  margin: 0 48rpx 32rpx;
  background: linear-gradient(135deg, #D73B3B, #E85D3A);
  border-radius: 44rpx; padding: 36rpx 40rpx;
  box-shadow: 0 12rpx 48rpx rgba(215,59,59,0.25);
  position: relative; overflow: hidden;
}
.em-deco {
  position: absolute; right: -40rpx; top: -40rpx;
  width: 160rpx; height: 160rpx; border-radius: 80rpx;
  background: rgba(255,255,255,0.08);
}
.em-badge {
  display: inline-block; padding: 4rpx 20rpx; border-radius: 16rpx;
  background: rgba(255,255,255,0.2); color: #fff;
  font-size: 20rpx; font-weight: 600; margin-bottom: 16rpx;
}
.em-name-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.em-name { font-size: 40rpx; font-weight: 700; color: #fff; }
.em-tag {
  padding: 2rpx 16rpx; border-radius: 12rpx;
  background: rgba(255,255,255,0.2); color: #fff; font-size: 22rpx;
}
.em-detail { display: block; font-size: 24rpx; color: rgba(255,255,255,0.8); margin-bottom: 4rpx; }
.em-hint { display: block; font-size: 20rpx; color: rgba(255,255,255,0.5); margin-top: 16rpx; }

/* Emergency Modal */
.modal-mask {
  position: fixed; inset: 0; z-index: 1000;
  background: rgba(0,0,0,0.6);
  display: flex; align-items: center; justify-content: center;
}
.modal-body {
  width: 85%; background: #fff; border-radius: 40rpx; overflow: hidden;
}
.modal-header {
  background: linear-gradient(135deg, #D73B3B, #E85D3A);
  padding: 40rpx; display: flex; justify-content: space-between; align-items: center;
}
.modal-title { font-size: 36rpx; font-weight: 700; color: #fff; }
.modal-close {
  width: 60rpx; height: 60rpx; border-radius: 30rpx;
  background: rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 28rpx;
}
.modal-content { padding: 32rpx 40rpx 40rpx; }
.modal-row {
  display: flex; justify-content: space-between;
  padding: 20rpx 0; border-bottom: 1rpx solid var(--border);
}
.modal-row.full { flex-direction: column; gap: 8rpx; }
.modal-label { font-size: 26rpx; color: var(--sub); }
.modal-value { font-size: 30rpx; font-weight: 600; color: var(--text); }

/* Section Label */
.section-label {
  padding: 24rpx 48rpx 6rpx 48rpx;
  font-size: 24rpx; font-weight: 600; color: var(--sub); letter-spacing: 2rpx;
}

/* Menu Group */
.menu-group {
  margin: 12rpx 48rpx 0; background: var(--card);
  border-radius: 36rpx; overflow: hidden;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.menu-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}
.menu-item:last-child { border-bottom: none; }
.mi-icon { font-size: 36rpx; }
.mi-label { flex: 1; font-size: 28rpx; font-weight: 500; color: var(--text); }
.mi-desc { font-size: 24rpx; color: var(--muted); }
.mi-arrow { font-size: 32rpx; color: var(--muted); }
.mi-code {
  font-size: 32rpx; font-weight: 800; color: var(--primary);
  letter-spacing: 4rpx; font-family: 'Courier New', monospace;
}
.mi-copy {
  padding: 6rpx 24rpx; border-radius: 20rpx;
  background: var(--primary-light); color: var(--primary);
  font-size: 22rpx; font-weight: 500;
}

/* ══════════════════════════════
   Family Card
   ══════════════════════════════ */
.family-card {
  margin: 12rpx 48rpx 0;
  background: var(--card);
  border-radius: 36rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.fc-top { display: flex; align-items: center; gap: 20rpx; }
.fc-icon { font-size: 48rpx; }
.fc-info { flex: 1; }
.fc-name { display: block; font-size: 32rpx; font-weight: 700; color: var(--text); }
.fc-role {
  display: inline-block; margin-top: 4rpx;
  padding: 4rpx 16rpx; border-radius: 12rpx;
  background: var(--primary-light); color: var(--primary);
  font-size: 22rpx; font-weight: 500;
}
.fc-code-row {
  display: flex; align-items: center; gap: 16rpx;
  margin-top: 20rpx; padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}
.fc-code-label { font-size: 24rpx; color: var(--sub); }
.fc-code {
  font-size: 36rpx; font-weight: 800; color: var(--primary);
  letter-spacing: 6rpx; font-family: 'Courier New', monospace;
  flex: 1;
}
.fc-copy {
  padding: 8rpx 24rpx; border-radius: 20rpx;
  background: var(--primary-light); color: var(--primary);
  font-size: 24rpx; font-weight: 500;
}

/* ══════════════════════════════
   Member List
   ══════════════════════════════ */
.member-list {
  margin: 12rpx 48rpx 0;
  background: var(--card);
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.member-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}
.member-item:last-child { border-bottom: none; }
.mb-left { display: flex; align-items: center; gap: 20rpx; }
.mb-avatar {
  width: 72rpx; height: 72rpx; border-radius: 36rpx;
  background: var(--primary-light); color: var(--primary);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 700;
}
.mb-info { display: flex; flex-direction: column; gap: 4rpx; }
.mb-name { font-size: 28rpx; font-weight: 600; color: var(--text); }
.mb-role-tag {
  display: inline-block;
  padding: 2rpx 12rpx; border-radius: 8rpx;
  background: var(--bg); color: var(--sub);
  font-size: 20rpx; font-weight: 500;
}
.mb-role-tag.admin {
  background: var(--primary-light); color: var(--primary);
}
.mb-actions { display: flex; gap: 12rpx; }
.mb-detail {
  padding: 8rpx 24rpx; border-radius: 20rpx;
  background: var(--blue-light); color: var(--blue);
  font-size: 24rpx; font-weight: 500;
}
.mb-remove {
  padding: 8rpx 24rpx; border-radius: 20rpx;
  background: var(--accent-light); color: var(--accent);
  font-size: 24rpx; font-weight: 500;
}

/* ══════════════════════════════
   Join Modal
   ══════════════════════════════ */
.join-modal {
  width: 85%; background: var(--card);
  border-radius: 40rpx; overflow: hidden;
}
.jm-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 36rpx 40rpx 0;
}
.jm-title { font-size: 36rpx; font-weight: 700; color: var(--text); }
.jm-close {
  width: 56rpx; height: 56rpx; border-radius: 28rpx;
  background: var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: var(--sub);
}
.jm-body { padding: 32rpx 40rpx 40rpx; }
.jm-label {
  display: block; font-size: 26rpx; color: var(--sub);
  margin-bottom: 16rpx;
}
.jm-input {
  width: 100%; height: 96rpx;
  text-align: center;
  font-size: 40rpx; font-weight: 800;
  letter-spacing: 12rpx;
  font-family: 'Courier New', monospace;
  color: var(--text);
  background: var(--bg); border-radius: 24rpx;
  box-sizing: border-box; padding: 0 24rpx;
}
.jm-submit {
  margin-top: 32rpx; width: 100%;
  height: 88rpx; line-height: 88rpx;
  border-radius: 28rpx;
  background: var(--primary); color: #fff;
  font-size: 32rpx; font-weight: 700;
  border: none; padding: 0;
}

/* Logout */
.logout-btn {
  margin: 40rpx 48rpx;
  text-align: center; padding: 28rpx;
  background: var(--card); border-radius: 36rpx;
  color: var(--accent); font-size: 30rpx; font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}

/* ★ 注销账号按钮 */
.delete-account-btn {
  margin: 24rpx 48rpx 0;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  border-radius: 20rpx;
  background: transparent;
}

/* ══════════════════════════════
   ★ About FamilyWell Modal
   ══════════════════════════════ */
.about-modal {
  width: 80%;
  background: var(--card, #fff);
  border-radius: 40rpx;
  padding: 60rpx 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.about-logo {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}
.about-name {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text, #2C2925);
}
.about-slogan {
  font-size: 26rpx;
  color: var(--sub, #8B8680);
  margin-top: 8rpx;
}
.about-divider {
  width: 100%;
  height: 1rpx;
  background: var(--border, #E8E3DD);
  margin: 36rpx 0;
}
.about-info {
  width: 100%;
}
.about-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}
.about-label {
  font-size: 28rpx;
  color: var(--sub, #8B8680);
}
.about-value {
  font-size: 28rpx;
  color: var(--text, #2C2925);
  font-weight: 500;
}
.about-email {
  color: var(--primary, #2D8B6F);
}
.about-footer {
  margin-top: 32rpx;
}
.about-copyright {
  font-size: 22rpx;
  color: var(--muted, #A9A49E);
}
